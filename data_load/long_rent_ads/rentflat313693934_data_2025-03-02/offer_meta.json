ltyUserId": 6872021, "absoluteAvatarUrl": "https://www.cian.ru/api/get-avatar/?i=132749&t=2&p=2&timestamp=1728384194", "absoluteMiniAvatarUrl": "https://www.cian.ru/api/get-avatar/?i=132749&t=2&p=1&timestamp=1728384194", "experience": "1991", "accountType": "agency", "creationDate": "2012-07-09T13:58:58+00:00", "offersCount": 527}, "isCianPartner": false, "canShowOnline": false, "moderationInfo": {"qualityLevelInfo": {"levelSystemName": "max", "levelName": "Суперагент", "levelOrder": 4, "hasVerifiedDocuments": true, "highResponsibility": true, "isSuperAgent": true, "isSuperHost": false, "isBlocked": false, "showSuperHost": false, "showSuperAgent": true, "showHighResponsibility": true}, "isUserIdentified": true, "isUserIdentifiedByDocuments": true, "showUserIdentifiedByDocuments": false}, "isHidden": true, "metrics": [{"title": "На Циан", "value": "12 лет"}, {"title": "Объектов в работе", "value": "527"}], "agentLists": []}, "user": {"isAuthenticated": false, "permissions": {"canModerateUsers": false, "canModerateAnnouncements": false, "canModerateAnnouncementsExpert": false, "canViewUsers": false, "canViewAnnouncements": false}, "ga": {"type": "", "balance": 0, "packages": [], "emailMd5": ""}}, "agentAvailability": {"userId": 6872021, "available": true}, "agentReviews": {"approvedReviewsCount": 99, "entityName": "", "entityRate": 0.5111111111111111, "entityRateMax": 5, "entityRateMin": 1, "isNotificationDisabled": true, "isUserMobilePushSubscribed": false, "isUserSubscribed": false, "rateCounts": [{"count": 36, "rate": 5}, {"count": 2, "rate": 4}, {"count": 0, "rate": 3}, {"count": 4, "rate": 2}, {"count": 57, "rate": 1}], "reviews": [{"answers": [], "created": 1553765417, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1553765468}, "rate": 5, "reviewId": "192cbae4-513c-11e9-8f82-0242ac11001b", "status": "approved", "text": "Очень грамотный риэлтор Елена!!!\nВсе подробно объяснила, грамотно, приятная в Общение. Все очень понравилось. Выражаю благодарность!", "totalAnswers": 0, "updated": 1553765417, "user": {"avatarUrl": "https://www.cian.ru/img/cian/icon_old/100x100.gif", "id": 17401066, "name": "ID:17401066", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1555232032, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1556110015}, "rate": 5, "reviewId": "d41e9b54-5e92-11e9-9e48-0242ac11001f", "status": "approved", "text": "Елена Александровна самый грамотный и ответственный риелтер, с которым я когда - нибудь работала, а в аренде я более 25 лет. Она всегда отстаивает интересы клиента, не разводит на деньги, пунктуальна, искренне переживает за дело и надежна. Я всем её рекомендую, так как уверена, что Елена Александровна не подведёт. Спасибо большое за помощь.", "totalAnswers": 0, "updated": 1555232032, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=6811988&t=1&p=2", "id": 6811988, "name": "Умарова Ирина", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [{"answerId": "571f2d88-a313-11e9-8ebb-0242ac110028", "created": 1562763907, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1562936151}, "status": "approved", "text": "Спасибо, что выбрали нашу компанию.\nСлужба Качества \"ИНКОМ-недвижимость\"", "updated": 1562763907, "user": {"avatarUrl": "https://www.cian.ru/api/get-avatar/?i=59078&t=2&p=2&timestamp=1728384266", "id": 4667765, "name": "ИНКОМ-Недвижимость", "socialNetworks": []}, "userLikeStatus": "unknown"}], "created": 1559299358, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1561044076}, "rate": 5, "reviewId": "cf534002-8390-11e9-967f-0242ac110005", "status": "approved", "text": "ответил на все вопросы. передал информацию хозяину квартиры", "totalAnswers": 1, "updated": 1559299358, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=24512458&t=1&p=2", "id": 24512458, "name": "Казаков Вадим", "socialNetworks": [{"socialUid": "8863250", "type": "vk"}]}, "userLikeStatus": "unknown"}, {"answers": [{"answerId": "9345b4aa-8407-11ea-a8a0-0242ac110021", "created": 1587497865, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1587534138}, "status": "approved", "text": "правильно!", "updated": 1587497865, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=47919972&t=1&p=2", "id": 47919972, "name": "ID:47919972", "socialNetworks": []}, "userLikeStatus": "unknown"}], "created": 1565368895, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1566371228}, "rate": 1, "reviewId": "8d2d56f8-bac4-11e9-a22c-0242ac11003c", "status": "approved", "text": "Трубку подняла девушка, я объяснил подробнее некуда.... что хочу снять квартиру по данному адресу.... мне ответили что данная квартира была сдана ещё вчера.....но каким-то странным образом объявление висит в статусе \"Активно\"......когда я попросил подобрать мне идентичный вариант - девушка бросила трубку.......Неуважение к своим потенциальным Клиентам это огромный минус к данной Компании - никогда не стану её советовать знакомым и друзьям!", "totalAnswers": 1, "updated": 1565368895, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=35775350&t=1&p=2", "id": 35775350, "name": "ID:35775350", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1565692662, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1565786180}, "rate": 2, "reviewId": "616f408c-bdb6-11e9-a585-0242ac110021", "status": "approved", "text": "Предложили записать номер агента, что совершенно неудобно! На просьбу отправить мне номер сообщением, ответили, что сообщения они не отправляют. А мой номер могут передать агенту только когда он будет в офисе. На мой взгляд потеря времени и клиента", "totalAnswers": 0, "updated": 1565692662, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=19061859&t=1&p=2", "id": 19061859, "name": "ID:19061859", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1566584606, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1568012026}, "rate": 1, "reviewId": "195f72b6-c5d3-11e9-a3f9-0242ac110037", "status": "approved", "text": "пришли смотреть квартиру ,на фото было все замечательно ,в итоге пришли там гнилые полы ,скотч на окнах ,двери тоже гнилые ,потеря времени", "totalAnswers": 0, "updated": 1566584606, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=36927309&t=1&p=2", "id": 36927309, "name": "ID:36927309", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [{"answerId": "860f3670-ec41-11e9-8065-0242ac110010", "created": 1570810177, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1571298001}, "status": "approved", "text": "Благодарим за Ваш отзыв. Просим Вас связаться с руководителем офиса для предоставления дополнительных пояснений в целях устранения недопонимания в сложившейся ситуации.\nТелефон: +7(495)363-16-10\nEmail: Viktorova_NV@incom.ru\nС уважением, Викторова Надежда Владимировна", "updated": 1570810177, "user": {"avatarUrl": "https://www.cian.ru/api/get-avatar/?i=59078&t=2&p=2&timestamp=1728384266", "id": 4667765, "name": "ИНКОМ-Недвижимость", "socialNetworks": []}, "userLikeStatus": "unknown"}], "created": 1566897346, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1568039527}, "rate": 1, "reviewId": "40abcf70-c8ab-11e9-9aa5-0242ac110029", "status": "approved", "text": "я позвонила по одному объявлению, сотрудница агентства сказала,  что собственник сдаёт квартиру только семье, что нам как раз соответствует. Спросила про возраст ребенка, сказала, что уточнит и перезвонит мне через 30 минут. До вечера со мной никто так и не связался. Я сама перезвонила на следующий день, мне опять сказали, что уточнят ситуацию по этому объекту и перезвонят. Обратную связь я так и не получила!", "totalAnswers": 1, "updated": 1566897346, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=12001843&t=1&p=2", "id": 12001843, "name": "ID:12001843", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1571848366, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1572014912}, "rate": 1, "reviewId": "beddbe16-f5b2-11e9-a15e-0242ac11002e", "status": "approved", "text": "Риелтор Тамара хамоватая особа. Назначает встречи и не приходит. Видимо пенсионерка, работать не хочет. А за что тогда комиссию!", "totalAnswers": 0, "updated": 1571848366, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=44407546&t=1&p=2", "id": 44407546, "name": "ID:44407546", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1579271894, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1579592905}, "rate": 5, "reviewId": "fe015432-3936-11ea-9c33-0242ac11005f", "status": "approved", "text": "оперативно ответили на звонок. проверили актуальность предложения. в дальнейшем перевели на специалиста, который перед закреплением моих данных обратила внимание на все нюансы квартиры, которые меня могут смутить перед просмотром.", "totalAnswers": 0, "updated": 1579271894, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=45574159&t=1&p=2", "id": 45574159, "name": "Petrova Jane", "socialNetworks": [{"socialUid": "2513819668860606", "type": "fb"}]}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1580643300, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1581487498}, "rate": 2, "reviewId": "0c2ea2a0-45b0-11ea-97ee-0242ac11000f", "status": "approved", "text": "очень грубо отвечали,даже нехочеть отвечат", "totalAnswers": 0, "updated": 1580643300, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=48281214&t=1&p=2", "id": 48281214, "name": "ID:48281214", "socialNetworks": []}, "userLikeStatus": "unknown"}], "subscriptionEmail": "", "totalCount": 99}, "isHiddenByUser": false, "degradationInfo": {}, "newbuildingsNearby": {"title": "Своя квартира в новостройке поблизости", "text": "Успейте купить квартиру с выгодными ставками по ипотеке", "newbuildings": [{"imageUrl": "https://images.cdn-cian.ru/images/hideout-moskva-jk-2403362942-7.jpg", "url": "https://zhk-hide-out-i