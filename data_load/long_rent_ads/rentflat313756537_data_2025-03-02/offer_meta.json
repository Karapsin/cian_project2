sUserSubscribed": false, "rateCounts": [{"count": 4, "rate": 5}, {"count": 0, "rate": 4}, {"count": 0, "rate": 3}, {"count": 0, "rate": 2}, {"count": 1, "rate": 1}], "reviews": [{"answers": [], "created": 1650452724, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1650950958}, "rate": 5, "reviewId": "c6f3395a-c099-11ec-96ca-82563717a07e", "status": "approved", "text": "Хочу выразить искренние слова благодарности замечательному, прекрасному, компетентному риэлтору Кристине. Спасибо Вам за старание, ответственность и трепетное отношение к делу. Вы не просто отличный специалист, но и замечательный человек! Спасибо за Вашу доброжелательность, природное обаяние, чувство такта, терпение, позитивный настрой! Дальнейших успехов, здоровья, процветания!!!!\nРекомендую всем!!!", "totalAnswers": 0, "updated": 1650452724, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=84589817&t=1&p=2", "id": 84589817, "name": "Кузнецов Вячеслав", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1661197021, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1661942595}, "rate": 5, "reviewId": "cb7ac91a-2251-11ed-bb9f-128a9328832f", "status": "approved", "text": "Прекрасный специалист, знает свое дело, всем советую!", "totalAnswers": 0, "updated": 1661197021, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=55201053&t=1&p=2", "id": 55201053, "name": "ID:55201053", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [{"answerId": "f092b6ec-e432-11ed-b644-ce553194f77a", "created": 1682514295, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1682686719}, "status": "approved", "text": "Александр, как Вы могли приехать, если точная дата и время просмотра не были согласованы? Тем более не было никакого подтверждения. \nНе мы – риелторы, принимаем решение по поводу состава Арендаторов, а Владельцы. Я рекомендовала Вашу кандидатуру, но Вы не подошли по изначальным критериям. Ваше желание заселиться, я понимаю, однако начинать с ложной информации тоже не хорошо.", "updated": 1682514295, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=62050518&t=1&p=2", "id": 62050518, "name": "Vmestate Кристина", "socialNetworks": []}, "userLikeStatus": "unknown"}], "created": 1681653936, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1681814259}, "rate": 1, "reviewId": "c3052b4a-dc5f-11ed-b995-cad741169a27", "status": "approved", "text": "Не предупредила об отмене просмотра квартиры и об измененных условиях. Выехали из Подмосковья в выходной день, потратили на дорогу 2 часа. Не извинилась даже.", "totalAnswers": 1, "updated": 1681653936, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=26278785&t=1&p=2", "id": 26278785, "name": "ID:26278785", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1713512604, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1713961533}, "rate": 5, "reviewId": "80bc555e-fe20-11ee-a8b9-52d2ab2c2931", "status": "approved", "text": "Очень компетентный риэлтор, вежливая и пунктуальная, общались некоторое время по объекту, осталось положительное впечатление, рекомендую", "totalAnswers": 0, "updated": 1713512604, "user": {"avatarUrl": "https://www.cian.ru/api/get-avatar/?i=131286&t=2&p=2&timestamp=1635956138", "id": 2301523, "name": "Авраменко Виталий", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1723128331, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1723810464}, "rate": 5, "reviewId": "dcca5802-5594-11ef-9847-ae144ad8e0b4", "status": "approved", "text": "Сотрудничество с Кристиной оставило только положительные впечатления. Ее доверительные отношения с собственниками квартиры помогли договориться обо всех условиях и быстро выйти на сделку. Спасибо за сотрудничество!", "totalAnswers": 0, "updated": 1723128331, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=13022838&t=1&p=2", "id": 13022838, "name": "ID:13022838", "socialNetworks": []}, "userLi