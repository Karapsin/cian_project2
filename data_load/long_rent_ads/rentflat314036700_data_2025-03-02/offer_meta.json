ick", "floorMax": 6, "entrances": 6, "flatCount": 70, "isEmergency": false, "demolishedInMoscowProgramm": false, "houseHeatSupplyType": "central", "houseOverhaulFundType": "regionalOp", "houseGasSupplyType": "central", "houseOverlapType": "concrete", "lifts": 6, "seriesName": "Индивидуальный проект"}}, "stats": {"daily": 27, "total": 382, "totalViewsFormattedString": "382 просмотра, 27 за сегодня", "totalUniqueViewsFormattedString": "256 уникальных"}, "notes": {}, "agent": {"id": 12742412, "cianUserId": 12742412, "realtyUserId": 12742412, "accountType": "specialist", "companyName": "Частный маклер", "creationDate": "2016-11-28T23:58:34.840000+00:00", "name": "Сергей Коновалов", "isPro": true, "description": "Привет. Меня зовут Сергей Коновалов. 34 года. Родился и вырос в Москве. Хорошо знаю и очень люблю город. Интересуюсь архитектурой.\n\nСпециализируюсь на жилой недвижимости. За более чем 10 лет провел более 500 сделок. \n\nПсихолог по образованию, в работе ориентируюсь на долгосрочные доверительные отношения. В переговорах - на потребности клиента. \n\nУвлекаюсь фотографией. Стараюсь подчеркнуть все  достоинства прекрасных квартир с которыми посчастливилось работать.\nЛюблю находить творческие решения для каждой задачи моих клиентов.\n\nРад работать с теми, кто ценит свое время, комфорт в коммуникации, уверенность в каждом этапе сделки.", "phones": [{"confirmed": true}], "skills": [{"id": 711, "name": "жилая", "parentName": "Продажа недвижимости"}, {"id": 712, "name": "жилая", "parentName": "Аренда недвижимости"}], "absoluteAvatarUrl": "https://www.cian.ru/api/get-avatar/?i=241943&t=2&p=2&timestamp=1706707696", "absoluteMiniAvatarUrl": "https://www.cian.ru/api/get-avatar/?i=241943&t=2&p=1&timestamp=1706707696", "isDeveloper": false, "firstName": "Сергей", "lastName": "Коновалов", "experience": "с 2011 года", "isRecidivist": false, "isUserOffersHasErrors": false, "offersCount": 2, "offersLink": "https://www.cian.ru/agents/12742412/", "availableServices": {"isUploadsAvailable": true, "isCallTrackingAvailable": false, "isPhoneChangingAvailable": false, "isServicePackagesAvailable": true, "canUseHiddenBase": true}, "userType": "realtor_based", "removeCompetitor": false, "status": "published", "isSubAgent": false, "isMessagingEnabled": false, "isPassportVerified": true, "isSelfEmployed": false, "isPrivateBroker": true, "isCianPartner": false, "canShowOnline": true, "moderationInfo": {"qualityLevelInfo": {"levelSystemName": "max", "levelName": "Суперагент", "levelOrder": 4, "hasVerifiedDocuments": true, "highResponsibility": true, "isSuperAgent": true, "isSuperHost": false, "isBlocked": false, "showSuperHost": false, "showSuperAgent": true, "showHighResponsibility": true}, "isUserIdentified": true, "isUserIdentifiedByDocuments": true, "showUserIdentifiedByDocuments": false}, "isHidden": false, "agentLists": []}, "user": {"isAuthenticated": false, "permissions": {"canModerateUsers": false, "canModerateAnnouncements": false, "canModerateAnnouncementsExpert": false, "canViewUsers": false, "canViewAnnouncements": false}, "ga": {"type": "", "balance": 0, "packages": [], "emailMd5": ""}}, "agentAvailability": {"userId": 12742412, "available": false, "message": "Напишите ему или позвоните в рабочее время.", "title": "Специалист работает с 9:00 по 21:00.", "availableFrom": "2025-03-02T09:00:00+03:00", "availableTo": "2025-03-02T21:00:00+03:00"}, "agentReviews": {"approvedReviewsCount": 68, "entityName": "", "entityRate": 0.9764705882352942, "entityRateMax": 5, "entityRateMin": 1, "isNotificationDisabled": true, "isUserMobilePushSubscribed": false, "isUserSubscribed": false, "rateCounts": [{"count": 67, "rate": 5}, {"count": 0, "rate": 4}, {"count": 0, "rate": 3}, {"count": 0, "rate": 2}, {"count": 2, "rate": 1}], "reviews": [{"answers": [], "created": 1535897314, "dislikesCount": 0, "likesCount": 1, "moderation": {"date": 1535971607}, "rate": 5, "reviewId": "add2a446-aeb9-11e8-ae4f-0242ac110004", "status": "approved", "text": "Сергей сработал очень качественно! Был на связи, оперативно организовал показ жилья, а также встречу с собственником. На сделке дал комментарии по всем пунктам договора и был заинтересован, чтобы стороны максимально договорились по условиям аренды.\n\nРекомендую, как профессионала!", "totalAnswers": 0, "updated": 1535897314, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=17266727&t=1&p=2", "id": 17266727, "name": "Рублев Вадим", "socialNetworks": [{"socialUid": "427161783", "type": "vk"}]}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1540380393, "dislikesCount": 0, "likesCount": 1, "moderation": {"date": 1540392264}, "rate": 5, "reviewId": "a9355588-d77f-11e8-8bff-0242ac110038", "status": "approved", "text": "Спасибо вам, Сергей за помощь с арендой квартиры. По сравнению со многими риэлторами - вежливый и приятный в общении молодой человек.", "totalAnswers": 0, "updated": 1540380393, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=19502267&t=1&p=2", "id": 19502267, "name": "ID:19502267", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1541417399, "dislikesCount": 0, "likesCount": 1, "moderation": {"date": 1541514276}, "rate": 5, "reviewId": "21452950-e0ee-11e8-af5a-0242ac110013", "status": "approved", "text": "Сергеем, как специалистом и его подходом я абсолютно доволен. Вежливое и искреннее общение, заинтересованность в решении вопросов. Проактивная позиция.", "totalAnswers": 0, "updated": 1541417399, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=20054727&t=1&p=2", "id": 20054727, "name": "ID:20054727", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1541668891, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1541685518}, "rate": 5, "reviewId": "adb58f1c-e337-11e8-9bf5-0242ac110007", "status": "approved", "text": "Сергей, высококвалифицированный профессионал своего дела. Мы, как арендодатели, сотрудничаем с Сергеем не первый год. Выход на сделку происходит намного быстрее, по сравнению с работой других риелторов и агентств, с кем нам доводилось сотрудничать, и качество арендаторов, которых предлагает Сергей, очень высокое. А из личных качеств Сергея, нам хочется отметить интеллигентность, вежливость и пунктуальность. Сергей, спасибо Вам!", "totalAnswers": 0, "updated": 1541668891, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=13309339&t=1&p=2", "id": 13309339, "name": "ID:13309339", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1542187967, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1542206998}, "rate": 5, "reviewId": "3f5dffda-e7f0-11e8-8a64-0242ac110009", "status": "approved", "text": "Сергей, произвел очень приятное впечатление, был последовательным, пунктуальным, выполнял договоренности. Такие риэлторы, мягко говоря, большая редкость. \nРекомендую.", "totalAnswers": 0, "updated": 1542187967, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=18996602&t=1&p=2", "id": 18996602, "name": "Plekhanov Artem", "socialNetworks": [{"socialUid": "10215823333755360", "type": "fb"}]}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1548669574, "dislikesCount": 0, "likesCount": 0, "rate": 5, "reviewId": "69de3930-22e3-11e9-8e2c-0242ac110048", "status": "new", "text": "Уже не первый раз обращаюсь к Сергею за помощью. Умница! Берется за дело любой сложности. Подбирает клиентов точно в соответствии с нашими пожеланиями. Результат - 100%. Быстро и качественно! Спасибо тебе, Сергей! Всем рекомендую.", "totalAnswers": 0, "updated": 1548669574, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=12807902&t=1&p=2", "id": 12807902, "name": "ID:12807902", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1548919978, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1548946580}, "rate": 5, "reviewId": "6e80b4e2-252a-11e9-9688-0242ac11001d", "status": "approved", "text": "Приятный и вежливый парень, помог снять квартиру без комиссии. Был очень вежлив и тактичен. Спасибо", "totalAnswers": 0, "updated": 1548919978, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=13366223&t=1&p=2", "id": 13366223, "name": "ID:13366223", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1551779124, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1552638470}, "rate": 5, "reviewId": "6694eb82-3f2b-11e9-9ebc-0242ac110011", "status": "approved", "text": "Работой Сергея осталась довольна. Приятный в общении, обязательный, порядочный человек. Рекомендую.", "totalAnswers": 0, "updated": 1551779124, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=16378971&t=1&p=2", "id": 16378971, "name": "ID:16378971", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1554479434, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1554907109}, "rate": 5, "reviewId": "8c489ee4-57ba-11e9-bd26-0242ac110014", "status": "approved", "text": "Сергей, большое Вам спасибо! Было легко общаться, получил ответы на все свои вопросы.  Результат - съем нужной квартиры, достигнут за очень короткий срок. Вы - профессионал! Обязательно обращусь к Вам в будущем, если появится необходимость.", "totalAnswers": 0, "updated": 1554479434, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=24781855&t=1&p=2", "id": 24781855, "name": "ID:24781855", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [{"answerId": "526e7440-e5f0-11e9-afeb-0242ac110035", "created": 1570115594, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1570190976}, "status": "approved", "text": "Спасибо, Александр, вы тоже прекрасный клиент)", "updated": 1570115594, "user": {"avatarUrl": "https://www.cian.ru/api/get-avatar/?i=241943&t=2&p=2&timestamp=1706707696", "id": 12742412, "name": "Коновалов Сергей", "socialNetworks": []}, "userLikeStatus": "unknown"}], "created": 1570112327, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1570609819}, "rate": 5, "