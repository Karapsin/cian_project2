esCount": 136, "statusId": 5004}, {"count": 7, "housesCount": 53, "statusId": 5002}], "categoryId": 2002, "description": "Донстрой — ведущая девелоперская компания Москвы. С 1994 года компания построила около 5,5 млн кв. м недвижимости. Сегодня Донстрой реализует четыре масштабных проекта комплексного освоения территорий. Это жилой комплекс «Символ» в Лефортово (1,5 млн кв. м), новый проект компании «Остров» в Мневниковской пойме (1,5 млн кв. м), территория застройки в Раменках, где Донстрой возводит три жилых комплекса: «Река», «Огни», «Событие» (1,3 млн кв. м) — а также «Сердце Столицы» в Хорошево-Мневниках (814 тыс. кв. м). По данным ДОМ.РФ, Донстрой входит в топ-3 рейтинга по энергоэффективному строительству жилых комплексов среди девелоперских компаний на столичном рынке недвижимости. Строительство всех объектов осуществляется при поддержке финансового партнера — Банка ВТБ (ПАО).", "fromDeveloperPropsCount": 795, "hasSpecProject": false, "id": 6017, "isTest": false, "locationIds": [1, 371491, 425031], "logoUrl": "/api/get-company-logo/?id=6017&rnd=11943", "maxBet": 35000, "name": "ДОНСТРОЙ", "newobjectsCount": 48, "offersCount": 795, "phones": [], "promoCount": 0, "specProjectNewobjectsCount": 0, "status": 12, "website": "http://www.donstroy.com/", "yearFoundation": 1994, "reviewStats": {"reviewCount": 1537, "reviewCountText": "1537 отзывов", "totalRate": 4.7}, "advantages": null, "email": null, "emailForRequest": null, "headerImageUrl": null, "isReliable": false, "newbuildingIds": null, "stats": null, "url": "#", "workYears": null}, "offences": [], "bti": {"houseData": {"yearRelease": 2002, "houseMaterialType": "brick", "floorMax": 9, "entrances": 1, "flatCount": 71, "isEmergency": false, "demolishedInMoscowProgramm": false, "houseHeatSupplyType": "central", "houseOverhaulFundType": "specialOrg", "houseGasSupplyType": "without", "houseOverlapType": "concrete", "lifts": 6, "seriesName": "Индивидуальный проект"}}, "stats": {"daily": 13, "total": 883, "totalViews