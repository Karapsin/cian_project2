ption": "<p>Capital Group — крупная российская девелоперская компания, созданная в 1993 году. Основное направление деятельности компании — строительство многофункциональных комплексов, жилой и коммерческой недвижимости в Москве.</p>\r\n\r\n<p>В портфеле компании – 9 млн кв. м объектов в реализации. Capital Group возводит жилье бизнес, элит и премиум-класса, реализуя сложные и знаковые проекты в сфере высотного строительства, которые неоднократно отмечались профессиональными российскими и международными премиями.</p>\r\n\r\n<p>Среди знаковых проектов компании — жилые комплексы «Бадаевский», «Небо», «Медный 3.14», «Лица», многофункциональные комплексы «Город Столиц» и «ОКО», клубные дома Mon Cher, «Кутузовский 12», White Khamovniki,  комплекс небоскребов с квартирами Capital Towers, многофункциональный комплекс The Book, жилой квартал «Золотой», первый в России отель Mandarin Oriental Hotel в Москве и первые в стране брендированные квартиры на Софийской набережной.</p>", "fromDeveloperPropsCount": 131, "hasSpecProject": false, "id": 7063, "isTest": false, "locationIds": [1, 199519], "logoUrl": "/api/get-company-logo/?id=7063&rnd=876446", "maxBet": 80000, "name": "Capital Group", "newobjectsCount": 37, "offersCount": 131, "phones": [], "promoCount": 0, "specProjectNewobjectsCount": 0, "status": 12, "website": "http://capitalgroup.ru/", "yearFoundation": 1993, "reviewStats": {"reviewCount": 480, "reviewCountText": "480 отзывов", "totalRate": 4.4}, "advantages": null, "email": null, "emailForRequest": null, "headerImageUrl": null, "isReliable": false, "newbuildingIds": null, "stats": null, "url": "#", "workYears": null}, "offences": [], "bti": {"houseData": {"yearRelease": 2008, "houseMaterialType": "brick", "floorMax": 8, "entrances": 1, "flatCount": 32, "isEmergency": false, "demolishedInMoscowProgramm": false, "houseHeatSupplyType": "itp", "houseOverhaulFundType": "unknown", "houseGasSupplyType": "without", "houseOverlapType": "concrete", "lifts": 2, "seriesName": "Ин