ng": {}, "isRentByParts": false, "isDuplicate": false, "showWarningMessage": false, "isUnique": false, "isUniqueCheckDate": "2025-03-23", "isCianPartner": false, "isIllegalConstruction": false, "externalOfferUrl": "", "cianLayouts": null, "newbuilding": {"id": 0, "isFromBuilder": false, "isFromDeveloper": false, "isFromLeadFactory": false, "isFromSeller": false, "isReliable": false, "isTariffPremium": false, "isPremium": false, "name": "", "newbuildingFeatures": null, "showJkReliableFlag": false}, "demolishedInMoscowProgramm": false}, "seoLinks": [], "breadcrumbs": [{"url": "https://www.cian.ru/", "title": "Недвижимость в Москве"}, {"url": "https://www.cian.ru/snyat/", "title": "Аренда"}, {"url": "https://www.cian.ru/snyat-1-komnatnuyu-kvartiru/", "title": "Аренда 1-комнатных квартир в Москве"}, {"url": "https://www.cian.ru/snyat-1-komnatnuyu-kvartiru-moskovskaya-oblast-varshavskoe-shosse-064/", "title": "Варшавское шоссе"}, {"url": "https://www.cian.ru/snyat-1-komnatnuyu-kvartiru-moskovskaya-oblast-kaluzhskoe-shosse-0610/", "title": "Калужское шоссе"}, {"url": "https://www.cian.ru/snyat-1-komnatnuyu-kvartiru-moskva-metro-ulica-skobelevskaya/", "title": "метро Улица Скобелевская"}, {"url": "https://www.cian.ru/snyat-1-komnatnuyu-kvartiru-moskva-ulica-polyany-022905/", "title": "улица Поляны"}], "similarOffersMapQs": "engine_version=2&deal_type=rent&offer_type=flat&region=1&minprice=32300&maxprice=43700&room1=1&room2=1&type=4", "similarNewObjects": [], "linkToMap": "https://www.cian.ru/map/?engine_version=2&deal_type=rent&offer_type=flat&region=1&minprice=32300&maxprice=43700&room1=1&room2=1&type=4&zoom=16&center=55.555052%2C37.555621", "isFavorite": false, "offerFoldersCount": 0, "subscription": {"isSubscribed": false}, "priceChanges": [{"changeTime": "2025-02-06T13:26:24.887078+00:00", "priceData": {"currency": "rur", "price": 38000, "paymentPeriod": "monthly"}}, {"changeTime": "2025-01-14T17:38:39.894896+00:00", "priceData": {"currency": "rur", "price": 43000, "paymentPeriod": "monthly"}}], "newObject": {"name": "Столичные поляны", "advantages": [{"advantageType": "Finish", "characteristics": [], "images": [{"url": "https://images.cdn-cian.ru/images/96/635/961/1695366997-1.jpg"}], "title": "Отделка", "description": "Квартира готова к переезду и не требует ремонта, осталось лишь купить мебель. Все необходимые работы по отделке застройщик уже выполнил."}, {"advantageType": "Parking", "characteristics": [], "images": [{"url": "https://images.cdn-cian.ru/images/17/635/961/1695367105-1.jpg"}], "title": "Парковка", "description": "На подземных этажах «Столичных полян» будет расположен паркинг. С ним не придётся искать, где припарковаться, а ваш автомобиль будет всегда в безопасности.\n\nСпуститься к машине можно на лифте с любого этажа. В паркингах будут установлены надёжные системы вентиляции, пожаротушения и видеонаблюдения. А наша собственная система навигации поможет вам быстро найти место, где вы припарковались."}, {"advantageType": "Courtyard", "characteristics": [], "images": [{"url": "https://images.cdn-cian.ru/images/36/635/961/1695366393-1.jpg"}], "title": "Внутренний двор", "description": "Широкий и длинный бульвар связывает дома, игровые площадки, детские сады и парки района в единое целое. Это центр отдыха и общения всех жителей. Здесь можно гулять с детьми, кататься на велосипедах и роликах, играть, заниматься спортом или просто наслаждаться отдыхом, свежим воздухом и природой."}, {"advantageType": "Architecture", "characteristics": [], "images": [{"url": "https://images.cdn-cian.ru/images/55/635/961/1695365504-1.jpg"}, {"url": "https://images.cdn-cian.ru/images/95/635/961/1695365940-1.jpg"}], "title": "Архитектура", "description": "Дома в «Столичных полянах» — от 16 до 33 этажей. Такая разница в высоте создаёт визуальное разнообразие, архитектурный ритм и позволяет легче ориентироваться в кварталах. А ещё в квартиры и во дворы попадает больше солнечного света."}, {"advantageType": "InputGroups", "characteristics": [], "images": [{"url": "https://images.cdn-cian.ru/images/5/559/598/895955559-1.jpg"}, {"url": "https://images.cdn-cian.ru/images/5/559/598/895955560-1.jpg"}], "title": "Входная группа", "description": "В «Столичных полянах» просторные и светлые первые этажи. Высота потолков в них 3,6 метра, а двери стеклянные. У подъездов два выхода: на улицу и во двор. Не придётся обходить дом, если оставили машину на парковке, а дети будут выходить гулять минуя проезжую часть."}, {"advantageType": "Elevator", "characteristics": [], "images": [{"url": "https://images.cdn-cian.ru/images/86/635/961/1695366830-1.jpg"}], "title": "Лифт", "description": "Мы устанавливаем надёжные, вместительные и быстрые лифты. В них легко поместятся детская коляска, велосипед и даже новый диван.\n\nОтделка кабин гармонично сочетается с цветами фасадов. А благодаря специальным покрытиям лифты надолго сохранят безупречный внешний вид."}], "specifications": [{"title": "Класс", "value": "Комфорт"}, {"title": "Тип дома", "value": "Монолитный"}, {"title": "Парковка", "value": "Подземная, гостевая"}, {"title": "Отделка", "value": "Чистовая"}, {"title": "Тип комплекса", "value": "Жилой комплекс", "valueTooltipText": "Один или несколько многоквартирных домов, объединённых общей территорией и инфраструктурой."}], "promoInfos": [], "decorations": [{"description": "Квартира готова к переезду и не требует ремонта, осталось лишь купить мебель. Все необходимые работы по отделке застройщик уже выполнил.", "images": [{"thumbnailUrl": "https://static.cdn-cian.ru/frontend/feedteam/upload/images/newbuildings/58/d4/55963e195fff55312f286cf5c08b.png", "url": "https://static.cdn-cian.ru/frontend/feedteam/upload/images/newbuildings/2b/ea/f6e40e1504c7873fa47c790a2487.png"}, {"thumbnailUrl": "https://static.cdn-cian.ru/frontend/feedteam/upload/images/newbuildings/de/78/20cbb36c325c2fb225351656b290.png", "url": "https://static.cdn-cian.ru/frontend/feedteam/upload/images/newbuildings/50/9c/956678ba5245cddcec7137e19bf1.png"}, {"thu