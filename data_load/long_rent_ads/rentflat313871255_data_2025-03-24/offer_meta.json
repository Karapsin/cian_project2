on": false, "externalOfferUrl": "", "cianLayouts": null, "newbuilding": {"id": 0, "isFromBuilder": false, "isFromDeveloper": false, "isFromLeadFactory": false, "isFromSeller": false, "isReliable": false, "isTariffPremium": false, "isPremium": false, "name": "", "newbuildingFeatures": null, "showJkReliableFlag": false}, "demolishedInMoscowProgramm": false}, "seoLinks": [], "breadcrumbs": [{"url": "https://www.cian.ru/", "title": "Недвижимость в Москве"}, {"url": "https://www.cian.ru/snyat/", "title": "Аренда"}, {"url": "https://www.cian.ru/snyat-2-komnatnuyu-kvartiru/", "title": "Аренда 2-комнатных квартир в Москве"}, {"url": "https://www.cian.ru/snyat-2-komnatnuyu-kvartiru-moskva-metro-polezhaevskaya/", "title": "метро Полежаевская"}, {"url": "https://www.cian.ru/snyat-2-komnatnuyu-kvartiru-moskva-horoshevskoe-shosse-022372/", "title": "Хорошевское шоссе"}], "similarOffersMapQs": "engine_version=2&deal_type=rent&offer_type=flat&region=1&minprice=90950&maxprice=123049&room2=1&room3=1&type=4", "similarNewObjects": [], "linkToMap": "https://www.cian.ru/map/?engine_version=2&deal_type=rent&offer_type=flat&region=1&minprice=90950&maxprice=123049&room2=1&room3=1&type=4&zoom=16&center=55.775307%2C37.527238", "isFavorite": false, "offerFoldersCount": 0, "subscription": {"isSubscribed": false}, "priceChanges": [{"changeTime": "2025-03-04T07:14:55.638420+00:00", "priceData": {"currency": "rur", "price": 107000, "paymentPeriod": "monthly"}}, {"changeTime": "2025-02-25T15:57:46.118965+00:00", "priceData": {"currency": "rur", "price": 115000, "paymentPeriod": "monthly"}}, {"changeTime": "2025-02-25T15:27:10.458735+00:00", "priceData": {"currency": "rur", "price": 120000, "paymentPeriod": "monthly"}}, {"changeTime": "2025-02-21T16:02:57.252236+00:00", "priceData": {"currency": "rur", "price": 125000, "paymentPeriod": "monthly"}}, {"changeTime": "2025-02-18T15:07:49.315404+00:00", "priceData": {"currency": "rur", "price": 126000, "paymentPeriod": "monthly"}}], "newObject": {"name": "Династия", "advantages": [{"advantageType": "Parking", "characteristics": [], "images": [{"url": "https://images.cdn-cian.ru/images/3/014/598/895410304-1.jpg"}], "title": "Парковка", "description": "К услугам жителей — двухуровневый подземный паркинг на 1200 машиномест с автоматизированной системой доступа на территорию. Посетители ЖК «Династия» смогут воспользоваться гостевой автостоянкой.\nВ паркинге предусмотрена система зарядки электромобилей, что, несомненно, оценят те, для кого автомобиль — не просто средство передвижения, а настоящая страсть."}, {"advantageType": "Courtyard", "characteristics": [], "images": [{"url": "https://images.cdn-cian.ru/images/2/104/598/895401230-1.jpg"}, {"url": "https://images.cdn-cian.ru/images/3/104/598/895401301-1.jpg"}, {"url": "https://images.cdn-cian.ru/images/4/104/598/895401437-1.jpg"}, {"url": "https://images.cdn-cian.ru/images/4/104/598/895401480-1.jpg"}], "title": "Внутренний двор", "description": "Одна из главных достопримечательностей жилого комплекса — просторный двор-патио, полностью закрытый от посторонних глаз «личный» парк для жителей «Династии».\nПлощадки для малышей и тех, кто считает себя «уже совсем взрослым», просторные газоны с цветниками, амфитеатр и скейт-парк, — все условия для интересных прогулок и игр доступны внутри комплекса.\nУверены, что фитнес — залог хорошего дня? К вашим услугам беговые дорожки и спортивные тренажеры. Достаточно спуститься во двор."}, {"advantageType": "Parks", "characteristics": [], "images": [{"url": "https://images.cdn-cian.ru/images/7/114/598/895411737-1.jpg"}], "title": "Парки", "description": "На расстоянии менее одного километра от домов раскинулся парк «Берёзовая роща»."}, {"advantageType": "Architecture", "characteristics": [], "images": [{"url": "https://images.cdn-cian.ru/images/5/004/598/895400552-1.jpg"}, {"url": "https://images.cdn-cian.ru/images/5/004/598/895400556-1.jpg"}, {"url": "https://images.cdn-cian.ru/images/5/004/598/895400583-1.jpg"}], "title": "Архитектура", "description": "Архитектурная концепция жилого комплекса — тонко переосмысленная тема монументальной классики. Комбинация элементов ампира, эклектики и ар-деко в актуальном прочтении архитекторов Sezar Group органичны восприятию всех поколений. Выверенная чистота линий и подчеркнутая симметрия продолжают династию архитектурных шедевров, формирующих сегодня облик столицы. "}, {"advantageType": "InputGroups", "characteristics": [], "images": [{"url": "https://images.cdn-cian.ru/images/8/404/598/895404803-1.jpg"}, {"url": "https://images.cdn-cian.ru/images/8/404/598/895404821-1.jpg"}, {"url": "https://images.cdn-cian.ru/images/8/404/598/895404834-1.jpg"}], "title": "Входная группа", "description": "Лобби жилого комплекса «Династия» — просторные холлы. Дизайн каждого — уникальный авторский проект. Каждый интерьер — произведение искусства, где множество деталей, но нет ничего лишнего.\nБлагородные материалы выгодно подчеркивают силуэт пространства, а стильные аксессуары дополняют образ истинной респектабельности и особого статуса, заметных даже искушенному взгляду."}, {"advantageType": "Elevator", "characteristics": [], "images": [{"url": "https://images.cdn-cian.ru/images/5/304/598/895403591-1.jpg"}], "title": "Лифт", "description": "Бесшумный лифт от ThyssenKrupp доставит вас в квартиру, технология «оптика в дом» обеспечит надежную связь — тысячи скрытых от глаз механизмов позаботятся обо всех аспектах вашего комфорта."}], "specifications": [{"title": "Класс", "value": "Бизнес"}, {"title": "Тип дома", "value": "Монолитно-кирпичный, монолитный"}, {"title": "Парковка", "value": "Подземная, гостевая"}, {"title": "Отделка", "value": "Без отделки"}, {"title": "Тип комплекса", "value": "Жилой комплекс", "valueTooltipText": "Один или несколько многоквартирных домов, объединённых общей территорией и инфраструктурой."}], "promoInfos": [], "decorations": [{"description": "В квартире имеются несущие межквартирные стены. Межкомнатные перегородки и электрическая разводка отсутствуют.\nВыполнено остекление окон, установлена входная дверь, часто осуществлена разводка труб отопления и установлены радиаторы, подведены инженерные коммуникации (трубы холодного и горячего водоснабжения, канализация, электрическая сеть), имеется общедомовая вентиляция.", "images": [{"thumbnailUrl": "https://static.cdn-cian.ru/frontend/feedteam/upload/images/newbuildings/3d/3b/f4d8e042617493c48a61e6d35f09.jpeg", "url": "https://static.cdn-cian.ru/frontend/feedteam/upload/images/newbuildings/5d/94/21ae7a5be698b78739f71861ee44.jpeg"}, {"thumbnailUrl": "https://static.cdn-cian.ru/frontend/feedteam/upload/images/newbuildings/75/fb/e4e477dcbcd7dbd3995e37670412.jpeg", "url": "https://static.cdn-cian.ru/frontend/feedteam/upload/images/newbuildings/16/59/bb0d21610bc850ada9e820cbf5a7.jpeg"}, {"thumbnailUrl": "https://static.cdn-cian.ru/frontend/feedteam/upload/images/newbuildings/a2/2d/342833965c53d5c0c5f07bfb1d86.jpeg", "url": "https://static.cdn-cian.ru/frontend/feedteam/upload/images/newbuildings/db/11/9a00d7e6ff41dcb8a78727ce8c96.jpeg"}], "shortDescription": "", "title": "Без отделки", "type": "without", "housesIds": [40166, 40168, 40167], "searchUrl": "https://cian.ru/cat.php?deal_type=sale&offer_type=flat&engine_version=2&object_type[0]=2&from_developer=1&newobject[0]=19800&decorations_list[0]=without"}], "newbuildingFeatures": {"imagesCount": 66, "firstImageUrl": "https://images.cdn-cian.ru/images/30/829/531/dinastiya-moskva-jk-1359280304-6.jpg", "videosCount": 3, "reviewsCount": 0, "hasProgressOfConstructions": true}, "id": 19800, "url": "/zhiloy-kompleks-dinastiya-moskva-19800/", "status": "Сдан", "developer": {"id": 8577, "url": "/zastroishchik-sezar-group-8577/", "name": "Sezar Group", "logoUrl": "/api/get-company-logo/?id=8577&rnd=482354", "stats": {"progress": {"text": "4 дома в 1 ЖК", "qs": "builder=8577&deal_type=sale&engine_version=2&offer_type=newobject&status%5B0%5D=5002"}, "done": {"text": "24 дома в 4 ЖК", "qs": "builder=8577&deal_type=sale&engine_ve