": 2}, {"count": 43, "rate": 1}], "reviews": [{"answers": [], "created": 1566898787, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1588230466}, "rate": 5, "reviewId": "9bdf5146-c8ae-11e9-a652-0242ac110086", "status": "approved", "text": "Все чётко и по существу. Светлана все грамотно объяснила", "totalAnswers": 0, "updated": 1566898787, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=38317001&t=1&p=2", "id": 38317001, "name": "Кучерова Дарья", "socialNetworks": [{"socialUid": "1850038365141579", "type": "fb"}]}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1567435698, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1568276711}, "rate": 3, "reviewId": "b3f06266-cd90-11e9-ac37-0242ac11005d", "status": "approved", "text": "квартира не готова к показу, риэлтер не может назвать сроки.", "totalAnswers": 0, "updated": 1567435698, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=30098689&t=1&p=2", "id": 30098689, "name": "P Max", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [{"answerId": "289d0b5a-ee78-11e9-86f1-0242ac11002d", "created": 1571053545, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1571303396}, "status": "approved", "text": "Добрый день! Вы как риэлтор знаете, что ценообразование при реализации квартир/комнат  диктует собственник квартиры/комнаты, в связи с этим не понятен Ваш отзыв о работе агентства, ведь не мы устанавливаем стоимость объекта. Очень просим Вас связаться с руководителем офиса для предоставления дополнительных пояснений в целях устранения недопонимания в сложившейся ситуации.\nТелефон: +7(495)363-16-00", "updated": 1571053545, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=6784887&t=1&p=2", "id": 6784887, "name": "ID:64027", "socialNetworks": []}, "userLikeStatus": "unknown"}], "created": 1568738078, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1569830409}, "rate": 2, "reviewId": "0a97a84c-d969-11e9-be08-0242ac11001c", "status": "approved", "text": "риэлтор Геннадий в своем стиле работы остался где-то в прошлом: разговаривает высокомерно, грубовато. Под разными предлогами пытался отговорить от просмотра комнаты по адресу: Москва, шоссе Энтузиастов, дом 96. Здесь и - цена для двоих будет выше, чем указано в объявлении - комната, оказывается, проходная (что не указано в объявлении) - собственница живёт с сыном 30 лет. А на следущий день прямым текстом сообщил, что у него есть более интересный (прямой) клиент, что работать с контрагентом ему в данном случае невыгодно (при том что в рекламе комиссия для риэлтора указана 50%, для прямого клиента - 80%).", "totalAnswers": 1, "updated": 1568738207, "user": {"avatarUrl": "https://www.cian.ru/api/get-avatar/?i=26584&t=2&p=2", "id": 1645222, "name": "Музалевский Иван", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [{"answerId": "d279d3de-ee77-11e9-968e-0242ac110030", "created": 1571053401, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1571303307}, "status": "approved", "text": "Благодарим за Ваш отзыв. Просим Вас по возможности связаться с руководителем офиса для предоставления дополнительных пояснений в целях устранения недопонимания в сложившейся ситуации.\nТелефон: +7(495)363-16-00\nEmail:Nikitenko_S@incom.ru\nС уважением, Никитенко Светлана Валентиновна.", "updated": 1571053401, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=6784887&t=1&p=2", "id": 6784887, "name": "ID:64027", "socialNetworks": []}, "userLikeStatus": "unknown"}], "created": 1569936967, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1569941124}, "rate": 1, "reviewId": "6c091e06-e450-11e9-9620-0242ac110061", "status": "approved", "text": "Хотели посмотреть квартиру по адресу ул. Фабрициуса 23к1. Меня перевели на агента, которая занимается продажей этой квартиры. Настолько пренебрежительного отношения я ещё не видела. За что я должна платить деньги агенту, когда она даже на вопросы не может адекватно отвечать. \nВот выставила фото. Не видела спального места, потому что на фото его просто нет. Спокойно спросила насчёт него, в ответ услышала чуть ли не крики, что я не туда смотрю, и нагло предложила смотреть внимательнее, после чего скинула трубку. \nНе агенство - а рынок по продаже неквалифицированных и непрофессиональных агентов!!!", "totalAnswers": 1, "updated": 1569937156, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=38773246&t=1&p=2", "id": 38773246, "name": "Dubkova Elena", "socialNetworks": [{"socialUid": "2396787953730675", "type": "fb"}]}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1569936974, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1586863424}, "rate": 1, "reviewId": "703179e2-e450-11e9-9620-0242ac110061", "status": "approved", "text": "Хотели посмотреть квартиру по адресу ул. Фабрициуса 23к1. Меня перевели на агента, которая занимается продажей этой квартиры. Настолько пренебрежительного отношения я ещё не видела. За что я должна платить деньги агенту, когда она даже на вопросы не может адекватно отвечать. \nВот выставила фото. Не видела спального места, спокойно спросила насчёт него, в ответ услышала чуть ли не крики, что я невнимательно смотрю, и нагло предложила смотреть внимательнее и скинула трубку. \nНе агенство - а рынок по продаже неквалифицированных и непрофессиональных агентов!!!", "totalAnswers": 0, "updated": 1569936974, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=38773246&t=1&p=2", "id": 38773246, "name": "Dubkova Elena", "socialNetworks": [{"socialUid": "2396787953730675", "type": "fb"}]}, "userLikeStatus": "unknown"}, {"answers": [{"answerId": "8c87c0ca-ee77-11e9-b946-0242ac11005d", "created": 1571053283, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1571303290}, "status": "approved", "text": "Добрый день.\nПросим Вас связаться с Руководителем офиса для уточнения сведений по Вашему отзыву в целях его рассмотрения по существу, так как агентство всегда участвует в урегулировании споров между сторонами сделки в течение срока действия договора.\nТелефон: +7(495)363-16-00\nEmail:Nikitenko_S@incom.ru\nС уважением, Никитенко Светлана Валентиновна", "updated": 1571053283, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=310277&t=1&p=2", "id": 310277, "name": "ID:212083", "socialNetworks": []}, "userLikeStatus": "unknown"}], "created": 1570628678, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1571046318}, "rate": 1, "reviewId": "f01bbab4-ea9a-11e9-881e-0242ac110045", "status": "approved", "text": "Мошенники. Хозяева не отдают страховой депозит. Работают с одним и тем же агентом. Люди не адекватные. Будьте осторожны.", "totalAnswers": 1, "updated": 1570628678, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=43777971&t=1&p=2", "id": 43777971, "name": "ID:43777971", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1575626395, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1575881167}, "rate": 1, "reviewId": "27a23bec-180f-11ea-8d17-0242ac110044", "status": "approved", "text": "Позвонил в офис Инком, уточнил адрес, который меня интересует. Сказали, что агент свяжется. Звонит агент - не представляется, на мой вопрос как я могу к вам обращаться - не реагирует, на вопросы по квартире отвечает резко, диалог вести не умеет, абсолютно бестактная и невоспитанная. Желание работать с таким риелтором отбивается на первых 15 секундах общения. Имя агента мне все-таки удалось выяснить - Джульетта.", "totalAnswers": 0, "updated": 1575626758, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=46297259&t=1&p=2", "id": 46297259, "name": "Kosto Adam", "socialNetworks": [{"socialUid": "10221328056496982", "type": "fb"}]}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1579433734, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1579691787}, "rate": 5, "reviewId": "ce5f2478-3aaf-11ea-89ed-0242ac110071", "status": "approved", "text": "Отличный специалист Татьяна очень хорошо провела консультацию и все подробно рассказала!", "totalAnswers": 0, "updated": 1579433734, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=47479516&t=1&p=2", "id": 47479516, "name": "ID:47479516", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [{"answerId": "1d30e95e-519b-11ea-b9b5-0242ac110045", "created": 1581953723, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1582806435}, "status": "approved", "text": "Благодарим за Ваш отзыв. Просим Вас по возможности связаться с руководителем офиса для предоставления дополнительных пояснений в целях устранения недопонимания в сложившейся ситуации.\nТелефон: +7(495)363-16-00\nEmail:Nikitenko_S@incom.ru\nС уважением, Никитенко Светлана Валентиновна.", "updated": 1581953723, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=6784887&t=1&p=2", "id": 6784887, "name": "ID:64027", "socialNetworks": []}, "userLikeStatus": "unknown"}], "created": 1581024755, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1581322629}, "rate": 1, "reviewId": "30d1a262-4928-11ea-9e27-0242ac11002c", "status": "approved", "text": "Позвонил, когда посмотреть можно? Спросили \"а зачем?\", смотрите все на фото! \nКурить можно в квартире? Да! \nС кошкой можно? Да! \nСдают надолго? От года и более! \nПо факту: с животными нельзя, курить нельзя, кран в ванной протекает, на кухне в шкафу под мойкой стоит тазик, тоже подтекает, стиралка недоавтомат не отжимает белье, а сдают на 2-3 месяца и не более. \nХотите потерять время? Обратитесь к этим недориэлторам-гастрабайтерам.", "totalAnswers": 1, "updated": 1581024755, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=45393106&t=1&p=2", "id": 45393106, "name": "ID:45393106", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1595850867, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1596165323}, "rate": 1, "reviewId": "ec17fe3c-cfff-11ea-a987-0242ac110073", "status": "approved", "text": "Информация в объявлении не соответствует тому что говорит специалист.", "totalAnswers": 0, "updated": 1595850867, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=6943715&t=1&p=2", "id": 6943715, "name": "ID:530983", "socialNetworks": []}, "userLikeStatus": "unknown"}], "subscriptionEmail": "", "totalCount": 78}, "isHiddenByUser": false, "degradationInfo": {}, "newbuildingsNearby": {"title": "Своя квартира в новостройке поблизости", "text": "Успейте купить квартиру с выгодными ставками по ипотеке", "newbuildings": [{"imageUrl": "https://images.cdn-cian.ru/images/doro-mille-moskva-jk-2202607586-7.jpg", "url": "https://zhk-doro-mille-i.cian.ru/", "name": "ЖК «D'ORO MILLE (Доро Милле)»", "minPrice": "от 216 141 ₽/мес", "underground": {"name": "Киевская", "lineColor": "03238B"}, "analytics": {"id": 4457540, "position": 1, "type": "JK"}}, {"imageUrl": "https://images.cdn-cian.ru/images/02/688/041/badaevskiy-moskva-jk-1408862089-7.jpg", "url": "https://zhk-badaevskiy-i.cian.ru/", "name": "ЖК «Бадаевский»", "minPrice": "от 336 617 ₽/мес", "underground": {"name": "Москва-Сити", "lineColor": "009BD5"}, "analytics": {"id": 1900321, "position": 2, "type": "JK"}}, {"imageUrl": "https://images.cdn-cian.ru/images/capital-towers-moskva-jk-2053432132-7.jpg", "url": "https://zhk-capital-towers-i.cian.ru/", "name": "ЖК «Capital Towers (Капитал Тауэрс)»", "minPrice": "от 258 117 ₽/мес", "underground": {"name": "Москва-Сити", "lineColor": "009BD5"}, "analytics": {"id": 45865, "position": 3, "type": "JK"}}, {"imageUrl": "https://images.cdn-cian.ru/images/dom-dau-moskva-jk-2000896595-7.jpg", "url": "https://zhk-dom-dau-i.cian.ru/", "name": "ЖК «Дом Дау»", "minPrice": "от 148 417 ₽/мес", "underground": {"name": "Москва-Сити", "lineColor": "009BD5"}, "analytics": {"id": 4296442, "position": 4, "type": "JK"}}], "buttonLink": "https://www.cian.ru/map/?engine_version=2&deal_type=sale&offer_type=flat&object_type%5B0%5D=2&zoom=12&center=55.744161%2C37.550944", "buttonText": "Смотреть все предложения"}, "rosreestrInfoV2": {"showCheckedL