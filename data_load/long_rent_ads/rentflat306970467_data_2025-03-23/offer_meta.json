ate": "2025-03-22", "isCianPartner": false, "isIllegalConstruction": false, "externalOfferUrl": "", "cianLayouts": null, "newbuilding": {"id": 0, "isFromBuilder": false, "isFromDeveloper": false, "isFromLeadFactory": false, "isFromSeller": false, "isReliable": false, "isTariffPremium": false, "isPremium": false, "name": "", "newbuildingFeatures": null, "showJkReliableFlag": false}, "demolishedInMoscowProgramm": false}, "seoLinks": [], "breadcrumbs": [{"url": "https://www.cian.ru/", "title": "Недвижимость в Москве"}, {"url": "https://www.cian.ru/snyat/", "title": "Аренда"}, {"url": "https://www.cian.ru/snyat-1-komnatnuyu-kvartiru/", "title": "Аренда 1-комнатных квартир в Москве"}, {"url": "https://www.cian.ru/cat.php?deal_type=rent&engine_version=2&foot_min=25&metro%5B0%5D=399&offer_type=flat&only_foot=2&room1=1&type=4", "title": "метро Лианозово"}, {"url": "https://www.cian.ru/snyat-1-komnatnuyu-kvartiru-moskva-lobnenskaya-ulica-021376/", "title": "Лобненская улица"}], "similarOffersMapQs": "engine_version=2&deal_type=rent&offer_type=flat&region=1&minprice=63750&maxprice=86250&room1=1&room2=1&type=4", "similarNewObjects": [{"id": 297367500, "photoUrl": "https://images.cdn-cian.ru/images/2079135733-4.jpg", "roomTitle": "1-комн. кв", "addressStr": "Москва, ул. Корнейчука, 27", "floor": 8, "floorn": 8, "kitchenArea": 15.6, "livingArea": 12.5, "priceRur": 7582080, "publishedUserId": 34805758, "totalArea": 35.2, "undergroundInfo": {"lineColor": "A2A5B5", "name": "Бибирево", "type": "mow"}}], "linkToMap": "https://www.cian.ru/map/?engine_version=2&deal_type=rent&offer_type=flat&region=1&minprice=63750&maxprice=86250&room1=1&room2=1&type=4&zoom=16&center=55.887054%2C37.527858", "isFavorite": false, "offerFoldersCount": 0, "subscription": {"isSubscribed": false}, "priceChanges": [{"changeTime": "2025-03-03T07:30:20.582981+00:00", "priceData": {"currency": "rur", "price": 75000, "paymentPeriod": "monthly"}}, {"changeTime": "2025-01-07T12:21:54.733566+00:00", "priceData": {"currency": "rur", "price": 80000, "paymentPeriod": "monthly"}}, {"changeTime": "2024-09-06T08:14:01.695400+00:00", "priceData": {"currency": "rur", "price": 75000, "paymentPeriod": "monthly"}}], "newObject": {"name": "Дмитровский парк", "advantages": [{"advantageType": "Finish", "characteristics": [], "images": [{"url": "https://images.cdn-cian.ru/images/83/535/961/1695353815-1.jpg"}], "title": "Отделка", "description": "Квартиры в «Дмитровском парке» сдаются с готовой отделкой. Не придётся искать ремонтную бригаду, выбирать строительные материалы и думать, где проложить трубы, — переехать в новую уютную квартиру можно сразу после получения ключей.\n\nМы продумываем отделку до мелочей, чтобы жителям было комфортно: в квартирах будет полностью оборудована ванная комната и санузел, установлен электрощит, розетки и выключатели, проведён телевизионный и сетевой кабель.\n\nВ квартирах будут смонтированы натяжные потолки, установлены входная и межкомнатные двери. В санузлах мы уложим плитку, на кухне и в коридоре — влагостойкий ламинат, в комнатах — обычный ламинат. Перед тем как использовать материал в работе, мы обязательно его тестируем.\n\nГотовая отделка будет выполнена в нейтральных тонах. Стены будут оклеены белыми обоями — если захотите, их легко перекрасить в любой другой цвет. Окрашивать наши обои можно до семи раз. "}, {"advantageType": "Parking", "characteristics": [], "images": [{"url": "https://images.cdn-cian.ru/images/1963303769-1.jpg"}], "title": "Парковка", "description": "На подземных этажах «Дмитровского парка» будет паркинг на 905 машино-мест. С ним не придётся искать, где припарковаться, а ваш мотоцикл или автомобиль всегда будет в безопасности.\n\nСпуститься к машине можно на лифте с любого этажа. В паркингах будут установлены надёжные системы вентиляции, пожаротушения и видеонаблюдения. "}, {"advantageType": "Courtyard", "characteristics": [], "images": [{"url": "https://images.cdn-cian.ru/images/1/476/009/900674151-1.jpg"}, {"url": "https://images.cdn-cian.ru/images/11/829/831/1389281126-1.jpg"}], "title": "Внутренний двор", "description": "Двор-парк — это приватное пространство жителей: сюда можно попасть из подъезда или через калитку, приложив магнитный ключ.\nВо дворах-парках тихо и уютно: здесь много зелени и нет машин. Площадки для шумных видов спорта, например баскетбола или футбола, расположены с другой стороны домов.\n\nВ таком дворе приятно отдохнуть после работы или зарядиться энергией перед новым днём, погулять с детьми, поболтать с соседями, почитать в тени или позаниматься йогой. Круглый год дворы-парки выглядят свежими и опрятными: здесь растут цветы и злаки, яблони и вишни, ели и сосны. "}, {"advantageType": "Architecture", "characteristics": [], "images": [{"url": "https://images.cdn-cian.ru/images/0/376/009/900673095-1.jpg"}], "title": "Архитектура", "description": "Мы разрабатываем для наших домов десятки вариантов фасадов, поэтому ни один из них не похож на другой.\nДля наших фасадов мы используем только долговечные материалы, которые не требуют больших затрат в эксплуатации — керамическую плитку и кирпич. Все фасады имеют уникальные палитру, пластику и рисунок окон. Благодаря разным фасадам в районе легко ориентироваться, и у каждого комплекса, района или квартала — своя идентичность."}, {"advantageType": "InputGroups", "characteristics": [], "images": [{"url": "https://images.cdn-cian.ru/images/6/276/009/900672601-1.jpg"}], "title": "Входная группа", "description": "Входы на уровне земли\nПроекты ПИК устроены так, чтобы по ним было удобно перемещаться и пешком, и на самокате, и с коляской, и в инвалидном кресле. Для этого мы убрали ступеньки, пороги и пандусы на всей территории. \n\nВ «Дмитровском парке» просторные и светлые первые этажи с высокими потолками и стеклянными дверьми. У подъездов два выхода: на улицу и во двор. Не придётся обходить дом, если оставили машину на парковке, а дети будут выходить гулять минуя проезжую часть."}, {"advantageType": "Elevator", "characteristics": [], 