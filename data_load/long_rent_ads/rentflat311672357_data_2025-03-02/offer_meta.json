velType": "byFoot"}, {"id": 707, "directionIds": [11], "distance": "4.0", "time": 6, "name": "Тестовская", "travelType": "byCar"}, {"id": 694, "directionIds": [11], "distance": "4.0", "time": 49, "name": "Москва (Белорусский вокзал)", "travelType": "byFoot"}, {"id": 694, "directionIds": [11], "distance": "6.0", "time": 11, "name": "Москва (Белорусский вокзал)", "travelType": "byCar"}], "undergrounds": [{"id": 46, "name": "Киевская", "lineColor": "03238B", "travelType": "walk", "travelTime": 12, "url": "https://www.cian.ru/snyat-1-komnatnuyu-kvartiru-moskva-metro-kievskaya/", "underConstruction": false}, {"id": 115, "name": "Смоленская", "lineColor": "03238B", "travelType": "walk", "travelTime": 19, "url": "https://www.cian.ru/snyat-1-komnatnuyu-kvartiru-moskva-metro-smolenskaya/", "underConstruction": false}, {"id": 159, "name": "Краснопресненская", "lineColor": "800000", "travelType": "walk", "travelTime": 20, "url": "https://www.cian.ru/snyat-1-komnatnuyu-kvartiru-moskva-metro-krasnopresnenskaya/", "underConstruction": false}]}, "id": 311672357, "objectGuid": "9d8cfd44-ea01-4622-a890-15995743f492", "cianId": 311672357, "userId": 122076544, "publishedUserId": 122076544, "cianUserId": 122076544, "isByHomeowner": false, "description": "Если не отвечаю на телефон- пишите в чат . В приоритете всегда быть на связи.\nСтильная  квартира в здании гостиницы \"Украина\", недалеко от метро \"Киевская\". Комнаты меблированы в эко стиле, все материалы натуральные ( в ванной комнате полы из экзотического дерева тик, стены натуральный перламутр, гигиенический душ, оснащена безопасной системой Нептун от протечки воды. В комнате: массивная доска Кумару, ортопедический матрац, итальянская кухня Virs,оборудована встроенной техникой холодильник, варочная панель. Есть отдельная вместительная гардеробная. Квартира светлая уютная для одного человека со всеми удобствами как в Отеле. На охраняемой территории есть паркинг. Развитая инфраструктура: Химчистка,швейное ателье, работают магазины, клиники, салоны красоты, кафе и рестораны, в доме есть фитнес центр с 50 метровым бассейном. ТЦ \"Европейский\", в пешей доступности - \"Москва-Сити\". Для прогулок - набережная Москвы-реки. Удобные выезды на Кутузовский проспект, Садовое кольцо.- Страховой депозит можно оплатить 2-мя частями.- На территории есть огражденная парковка - Дом находится на охраняемой территории.", "photos": [{"id": 2363073951, "isDefault": true, "fullUrl": "https://images.cdn-cian.ru/images/kvartira-moskva-kutuzovskiy-prospekt-2363073951-1.jpg", "thumbnailUrl": "https://images.cdn-cian.ru/images/kvartira-moskva-kutuzovskiy-prospekt-2363073951-2.jpg", "thumbnail2Url": "https://images.cdn-cian.ru/images/kvartira-moskva-kutuzovskiy-prospekt-2363073951-4.jpg", "miniUrl": "https://images.cdn-cian.ru/images/kvartira-moskva-kutuzovskiy-prospekt-2363073951-3.jpg", "isCianLayout": false}, {"id": 2363072717, "isDefault": false, "fullUrl": "https://images.cdn-cian.ru/images/kvartira-moskva-kutuzovskiy-prospekt-2363072717-1.jpg", "thumbnailUrl": "https://images.cdn-cian.ru/images/kvartira-moskva-kutuzovskiy-prospekt-2363072717-2.jpg", "thumbnail2Url": "https://images.cdn-cian.ru/images/kvartira-moskva-kutuzovskiy-prospekt-2363072717-4.jpg", "miniUrl": "https://images.cdn-cian.ru/images/kvartira-moskva-kutuzovskiy-prospekt-2363072717-3.jpg", "isCianLayout": false}, {"id": 2363073952, "isDefault": false, "fullUrl": "https://images.cdn-cian.ru/images/kvartira-moskva-kutuzovskiy-prospekt-2363073952-1.jpg", "thumbnailUrl": "https://images.cdn-cian.ru/images/kvartira-moskva-kutuzovskiy-prospekt-2363073952-2.jpg", "thumbnail2Url": "https://images.cdn-cian.ru/images/kvartira-moskva-kutuzovskiy-prospekt-2363073952-4.jpg", "miniUrl": "https://images.cdn-cian.ru/images/kvartira-moskva-kutuzovskiy-prospekt-2363073952-3.jpg", "isCianLayout": false}, {"id": 2363072707, "isDefault": false, "fullUrl": "https://images.cdn-cian.ru/images/kvartira-moskva-kutuzovskiy-prospekt-2363072707-1.jpg", "thumbnailUrl": "http