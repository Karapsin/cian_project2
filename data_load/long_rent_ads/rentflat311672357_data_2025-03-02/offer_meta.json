обные выезды на Кутузовский проспект, Садовое кольцо. Страховой депозит можно оплатить 2мя частями. На территории есть огражденная парковка  Дом находится на охраняемой территории.", "sku": 311672357, "brand": {"@type": "Brand", "name": "Циан"}, "review": {"@type": "Review", "reviewRating": {"@type": "Rating", "ratingValue": 4.8, "bestRating": 5}, "author": {"@type": "Person", "name": "The Address"}}, "offers": {"@type": "Offer", "url": "https://www.cian.ru/rent/flat/311672357/", "priceCurrency": "RUB", "availability": "https://schema.org/InStock", "price": 115000}}}, "trackingUrl": "/rent/flat/JK/obl_id=1/city_id=1/object_type=/ga_obj_type=1/rent_type=long/spec=company/311672357/from_developer=0/repres=0/owner=0/pod_snos=0/nv=0/", "amenities": [{"title": "В квартире есть", "id": "flatRent", "amenities": [{"value": "Кондиционер", "theme": "cond"}, {"value": "Интернет", "theme": "internet"}, {"value": "Ванна", "theme": "bath"}, {"value": "Мебель в комнатах", "theme": "furniture"}]}], "newbuildingRating": 0, "offerPrice": "115 000 ₽/мес.", "company": null}, "promotionsVillageData": {}, "offerStatsPopup": {"dataStats": null, "isOpen": false, "messageError": "", "statusFetch": 0}, "pageData": {"dealType": "rent", "offerId": 311672357, "offerType": "flat", "subdomain": "www"}, "phoneCollapse": false, "phoneWarning": {"isOpen": false, "target": null}, "printModal": {"isCommentsVisible": true, "isOpen": false, "isPhonesVisible": true, "isPrintModeEnabled": false}, "pushSubscribed": false, "reclaimModal": {"errorMessage": "", "isOpen": false, "statusFetch": "none"}, "remove": {"activeFrame": "initial", "isOpen": false, "status": "default"}, "seoLinks": {"isLoad": false, "seoLinks": {"seoBlocks": []}}, "serviceBaseUrl": "https://service.cian.ru/", "similarOffers": {"userBased": {"list": [], "withoutCompetitors": false, "modelVersion": ""}, "itemBased": {"list": [], "withoutCompetitors": false, "modelVersion": ""}, "historyBased": {"list": [], "withoutCompetitors": false, "mo