нотеатры, музеи, школы и станция метро \"Смоленская\". Для прогулок подойдет Пресненский парк и Смоленская набережная. Удобный выезд на Кутузовский проспект и Садовое кольцо.\n\n - Страховой депозит можно оплатить 2-мя частями.\n - Квартиру представляет агент Capital Mars - Анастасия.\n - ID объекта 1825.", "photos": [{"id": 2392902113, "isDefault": false, "fullUrl": "https://images.cdn-cian.ru/images/2392902113-1.jpg", "thumbnailUrl": "https://images.cdn-cian.ru/images/2392902113-2.jpg", "thumbnail2Url": "https://images.cdn-cian.ru/images/2392902113-4.jpg", "miniUrl": "https://images.cdn-cian.ru/images/2392902113-3.jpg", "isLayout": false, "isCianLayout": false}, {"id": 2392902134, "isDefault": false, "fullUrl": "https://images.cdn-cian.ru/images/2392902134-1.jpg", "thumbnailUrl": "https://images.cdn-cian.ru/images/2392902134-2.jpg", "thumbnail2Url": "https://images.cdn-cian.ru/images/2392902134-4.jpg", "miniUrl": "https://images.cdn-cian.ru/images/2392902134-3.jpg", "isLayout": false, "isCianLayout": false}, {"id": 2392902159, "isDefault": false, "fullUrl": "https://images.cdn-cian.ru/images/2392902159-1.jpg", "thumbnailUrl": "https://images.cdn-cian.ru/images/2392902159-2.jpg", "thumbnail2Url": "https://images.cdn-cian.ru/images/2392902159-4.jpg", "miniUrl": "https://images.cdn-cian.ru/images/2392902159-3.jpg", "isLayout": true, "isCianLayout": false}, {"id": 2392902174, "isDefault": false, "fullUrl": "https://images.cdn-cian.ru/images/2392902174-1.jpg", "thumbnailUrl": "https://images.cdn-cian.ru/images/2392902174-2.jpg", "thumbnail2Url": "https://images.cdn-cian.ru/images/2392902174-4.jpg", "miniUrl": "https://images.cdn-cian.ru/images/2392902174-3.jpg", "isLayout": false, "isCianLayout": false}, {"id": 2392902221, "isDefault": false, "fullUrl": "https://images.cdn-cian.ru/images/2392902221-1.jpg", "thumbnailUrl": "https://images.cdn-cian.ru/images/2392902221-2.jpg", "thumbnail2Url": "https://images.cdn-cian.ru/images/2392902221-4.jpg", "miniUrl": "https://imag