: 101, "rate": 5}, {"count": 0, "rate": 4}, {"count": 0, "rate": 3}, {"count": 0, "rate": 2}, {"count": 7, "rate": 1}], "reviews": [{"answers": [], "created": 1598340941, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1598443718}, "rate": 5, "reviewId": "942fda34-e6a5-11ea-a86c-0242ac11005a", "status": "approved", "text": "хороший риелтор, сделка прошла успешно, всем доволен.", "totalAnswers": 0, "updated": 1598340941, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=14885408&t=1&p=2", "id": 14885408, "name": "Урал  Дмитрий ", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1598474861, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1598617395}, "rate": 5, "reviewId": "62a5208a-e7dd-11ea-bced-0242ac11002a", "status": "approved", "text": "Ярослав  отличный  Риэлтор  настоящий профессионал также он отличный  человек  понимает  пожелания  клиента с ним очень  приятно  общаться\n\nПровела  две сделки клиентов нашел  быстро документы  оформлены идеально ,свою работу  делает честно,практически все сделал  за меня очень легок  на подьем все время в движение \nочень довольна  рекомендую", "totalAnswers": 0, "updated": 1598474861, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=12746409&t=1&p=2", "id": 12746409, "name": "ID:12746409", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1598553394, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1599034287}, "rate": 5, "reviewId": "3bb32a50-e894-11ea-a6ef-0242ac11006e", "status": "approved", "text": "Ярослав был всегда на связи, максимально  включенный в процесс сделки. Очень довольна его работой! Покупка прошла гладко, человек знает свое дело и очень внимателен в документах.", "totalAnswers": 0, "updated": 1598553394, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=324864&t=1&p=2", "id": 324864, "name": "ID:7361363", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1598798543, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1599111471}, "rate": 5, "reviewId": "0404e390-eacf-11ea-9974-0242ac110075", "status": "approved", "text": "Ярослав оказался самым коммуникабельным, порядочным и надежным риелтором из всех, к кому мы обращались. Всегда вежлив, тактичен, пунктуален, готов показывать объект в любое время, владеет обширной клиентской базой, грамотно ведёт диалог, быстро нашёл для нас покупателя. Продали квартиру за ту цену, которую хотели. Довольны сделкой на 100%. Одним словом, профессионал своего дела!", "totalAnswers": 0, "updated": 1598798543, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=57684899&t=1&p=2", "id": 57684899, "name": "ID:57684899", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1598812378, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1599121840}, "rate": 5, "reviewId": "3a50980c-eaef-11ea-8ff1-0242ac110048", "status": "approved", "text": "Обязателен, не бросает слов на ветер, коммуникабелен, относится к своей работе с душой и классный специалист - именно такое мнение сложилось у меня после завершения сделки по продаже\n квартиры о Ярославе. Большое спасибо и пусть удача Ярослав вам сопутствует во всем.", "totalAnswers": 0, "updated": 1598812432, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=48307045&t=1&p=2", "id": 48307045, "name": "ID:48307045", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1603906296, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1604414807}, "rate": 5, "reviewId": "6e2aacd0-1943-11eb-8159-0242ac110047", "status": "approved", "text": "Отличный риелтор. Активный, много показов было. На всех этапах  сопровождал по сделке. Давал обратную связь  по показам.  Всем доволен. Хороший человек, с которым приятно работать. Сделка прошла хорошо. Спасибо!", "totalAnswers": 0, "updated": 1603906296, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=49044234&t=1&p=2", "id": 49044234, "name": "ID:49044234", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1604416252, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1604923585}, "rate": 1, "reviewId": "c3577678-1de6-11eb-a124-0242ac110086", "status": "approved", "text": "Добрый день.\nПосле того как внесли полноценный аванс за эту квартиру, агент продолжает рекламировать. Для настоящего профи это неприемлемо ставлю 1 балл.", "totalAnswers": 0, "updated": 1604416252, "user": {"avatarUrl": "https://www.cian.ru/api/get-avatar/?i=26260777&t=2&p=2&timestamp=1719812875", "id": 13753360, "name": "Мынзэрару Роман", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1605774597, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1605878529}, "rate": 5, "reviewId": "684f686e-2a41-11eb-bb02-0242ac110094", "status": "approved", "text": "Ярослав МОЛОДЕЦ!!!Хочу выразить Ярославу огромную благодарность за помощь в продаже квартиры. Ярослав отличный клиентщик, ненавязчив, всегда доброжелателен, вежлив, никого не \"разводит\", а просто грамотно делает свою работу, отстаивая интересы клиента, что обещает то делает. Очень приятно было сотрудничать, буду и впредь к нему обращаться и рекомендовать его всем кому нужна помощь отличного риэлтора!!!", "totalAnswers": 0, "updated": 1605774597, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=57864940&t=1&p=2", "id": 57864940, "name": "ID:57864940", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1606592016, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1606828111}, "rate": 5, "reviewId": "9bdef26e-31b0-11eb-a833-0242ac11004d", "status": "approved", "text": "Отличный специалист! Сделка прошла легко и быстро. Ярослав очень тактичен, вежлив и коммуникабелен. Все показывал, рассказывал и объяснял. Огромное спасибо!", "totalAnswers": 0, "updated": 1606592016, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=15626642&t=1&p=2", "id": 15626642,