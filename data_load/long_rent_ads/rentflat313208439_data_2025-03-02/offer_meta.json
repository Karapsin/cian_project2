imestamp=1730215193", "experience": "2015", "accountType": "agency", "creationDate": "2023-07-20T10:36:50.693000+00:00", "offersCount": 165}, "isCianPartner": false, "canShowOnline": false, "moderationInfo": {"qualityLevelInfo": {"levelSystemName": "low", "levelName": "Агент", "levelOrder": 1, "hasVerifiedDocuments": false, "highResponsibility": false, "isSuperAgent": false, "isSuperHost": false, "isBlocked": false, "showSuperHost": false, "showSuperAgent": false, "showHighResponsibility": false}, "isUserIdentified": false, "isUserIdentifiedByDocuments": true, "showUserIdentifiedByDocuments": true}, "isHidden": true, "metrics": [{"title": "На Циан", "value": "1 год"}, {"title": "Объектов в работе", "value": "165"}], "agentLists": []}, "user": {"isAuthenticated": false, "permissions": {"canModerateUsers": false, "canModerateAnnouncements": false, "canModerateAnnouncementsExpert": false, "canViewUsers": false, "canViewAnnouncements": false}, "ga": {"type": "", "balance": 0, "packages": [], "emailMd5": ""}}, "agentAvailability": {"userId": 105523381, "available": false, "message": "Напишите ему или позвоните в рабочее время.", "title": "Специалист работает с 9:00 по 19:00.", "availableFrom": "2025-03-02T09:00:00+03:00", "availableTo": "2025-03-02T19:00:00+03:00"}, "agentReviews": {"approvedReviewsCount": 12, "entityName": "", "entityRate": 0.8666666666666666, "entityRateMax": 5, "entityRateMin": 1, "isNotificationDisabled": true, "isUserMobilePushSubscribed": false, "isUserSubscribed": false, "rateCounts": [{"count": 10, "rate": 5}, {"count": 0, "rate": 4}, {"count": 0, "rate": 3}, {"count": 0, "rate": 2}, {"count": 2, "rate": 1}], "reviews": [{"answers": [{"answerId": "2e8c6372-9e99-11ef-94d0-32a34e5b2c6e", "created": 1731156621, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1731308961}, "status": "approved", "text": "Добрый день! К сожалению, бывает такое, что агент ответственный за квартиру, может быть на показе, и соответсвенно Вам ответит другой. И на ликвидные объекты большой спрос, долго они не задерживаются. Вы могли звонить вечером, записаться на просмотр на следующий день, а тем же вечером квартиру могут забрать. \nТак же, квартира может быть под задатком, но пока не подпишут договор официально, она будет в рекламе. В любом случае, просим прощение за дискомфорт и если остались недопонимания или вопросы- пишите.", "updated": 1731156621, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=116992764&t=1&p=2", "id": 116992764, "name": "ID:116992764", "socialNetworks": []}, "userLikeStatus": "unknown"}], "created": 1731083790, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1731325689}, "rate": 1, "reviewId": "9b5e4e5c-9def-11ef-beb4-02b430a0a96f", "status": "approved", "text": "Позвонил по телефону , ответил другой человек , потом перезвонил 3 , оказалось , что объект уже сдан . Предложили другие варианты , но почему висит неактуальное объявление и нельзя указать номер именно того агента , который который занимается данной квартирой непонятно . Пришлось звонить , писать сообщения , чтобы в итоге узнать через несколько часов, что объект сдан, браво!", "totalAnswers": 1, "updated": 1731083790, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=13493282&t=1&p=2", "id": 13493282, "name": "ID:13493282", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1731227200, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1731416159}, "rate": 5, "reviewId": "829db610-9f3d-11ef-aa0f-22180e671f39", "status": "approved", "text": "Выражаю огромную благодарность Майе за то, как оперативно она сдала мою квартиру! 🙏 Клиентов поселила ответственных, платежеспособных. Как агент, Майя, очень внимательная и чуткая. Спасибо!", "totalAnswers": 0, "updated": 1731227200, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=124077594&t=1&p=2", "id": 124077594, "name": "ID:124077594", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1731227223, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1731416183}, "rate": 5, "reviewId": "909a06d8-9f3d-11ef-aa0d-72c9ee0b8987", "status": "approved", "text": "Остро встал вопрос поиска квартиры, быстро подобрали вариант  в короткие сроки с адекватным собственником. Очень  понравился подход и профессионализм, спасибо", "totalAnswers": 0, "updated": 1731227223, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=119355830&t=1&p=2", "id": 119355830, "name": "ID:119355830", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1731227248, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1731416527}, "rate": 5, "reviewId": "9f721cb8-9f3d-11ef-aa0f-22180e671f39", "status": "approved", "text": "лучший подход к клиентам !! лучшие квартиры, лучшие риелтора ! просто топ ! рекомендую всем своим родным и близким !!!) если вы хотите заселиться в квартиру без тараканов, как принято в Москве, то вам стоит обратиться только в это Агенство ! лучшие в своем деле 💫", "totalAnswers": 0, "updated": 1731227248, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=123525545&t=1&p=2", "id": 123525545, "name": "ID:123525545", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1731227296, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1731416549}, "rate": 5, "reviewId": "bbc29ac8-9f3d-11ef-939b-76b5252bc126", "status": "approved", "text": "Агент Майя помогла нам заселиться в квартиру, очень быстро устроила показ и помогла договориться на вывоз мебели!", "totalAnswers": 0, "updated": 1731227296, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=121147215&t=1&p=2", "id": 121147215, "name": "Бервинов  Данил", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1731917183, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1732097206}, "rate": 5, "reviewId": "004a554a-a584-11ef-804b-92242d81b981", "status": "approved", "text": "Огромное спасибо выражаю всей команде Лас Вегас! Отдельное спасибо агенту Диане! Нашли общий язык с первых минут, прониклась нашей ситуацией!  Позвонил, оперативно заселили. Договорилась с собственником на кошку. Не думал, что с кошкой заселят, тем более за пару часов. Лучшие!!!", "totalAnswers": 0, "updated": 1731917183, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=122141147&t=1&p=2", "id": 122141147, "name": "ID:122141147", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1732095449, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1732184471}, "rate": 5, "reviewId": "0f88c7a8-a723-11ef-8d78-ae6ba14c98c4", "status": "approved", "text": "Спасибо огромное агенту Майе! Обратилась по объявлению, через два часа устроила показ, но к сожалению, квартира оказалась маленькой, но Майя в течение 20 минут предложила другую квартиру, выявив мои хотели. Поехали и заселились! Отличная клиентоориентированность 🔥🫶🏻", "totalAnswers": 0, "updated": 1732095449, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=77956968&t=1&p=2", "id": 77956968, "name": "ID:77956968", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [{"answerId": "ac908f36-a827-11ef-b78c-e634dad39bd5", "created": 1732207382, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1732252070}, "status": "approved", "text": "Сергей, на один ликвидный объект бывает в день более 100 откликов. И к сожалению, агенты, ответственные за определенный объект могут быть на показе, и вовремя Вам не ответят. И, соответственно, из 10 кандидатов собственники выберут 1. Наши агенты, не могли Вам сообщить о «фейке». Приносим свои извинения, если Вы распознали какой-то акт мошенничества, приглашаем Вас в наш офис, метро Арбатская, ул. Воздвиженка 9с2. Спасибо!", "updated": 1732207382, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=124339227&t=1&p=2", "id": 124339227, "name": "ID:124339227", "socialNetworks": []}, "userLikeStatus": "unknown"}], "created": 1732203920, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1733573696}, "rate": 1, "reviewId": "9d23e776-a81f-11ef-9a44-6ecb773230ca", "status": "approved", "text": "2 раза данное ан недвижимости самым хамским образом обманули. Выкладывают фейковые объявления и дальше под предлогом \"вы не подходите собственнику\" отказывают и предлагают совершенно другие по цене и качеству варианты. Имейте это ввиду когда обращайтесь к ним. Это произошло 2 раза в течении 2 дней. В первом случае агент сразу честно сказал - что объявление фейковое. Во втором случае \"вы не подходите собственику. Смешно. По факту куча потраченного времени, поскольку до риелтора дозвониться сразу у вас не получиться и вам скажут, что нужно ждать. Желаю всем удачи и не связываться с подобными \"экспертами\"", "totalAnswers": 1, "updated": 1732203920, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=76664235&t=1&p=2", "id": 76664235, "name": "ID:76664235", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1732866352, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1732876411}, "rate": 5, "reviewId": "f553c8b0-ae25-11ef-902f-b2aa48f100f1", "status": "approved", "text": "Спасибо огромное самым лучшим специалистам! Заехали с мужем в квартиру мечты! Долго не могли определиться и с питомцем мало где нас брали. Заехали быстро, агент Роман сопровождал нас всю сделку. Очень оперативно, качественно! Мы очень довольны! ❤️", "totalAnswers": 0, "updated": 1732866352, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=125061312&t=1&p=2", "id": 125061312, "name": "Ковальчук  Надежда", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1733559257, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1733590626}, "rate": 5, "reviewId": "40e74c4a-b473-11ef-9472-c61a790c98be", "status": "approved", "text": "Девушка работает вне конкуренции\nПрофи в своем деле🙌🏽\nСпасибо🤝🏽", "totalAnswers": 0, "updated": 1733559257, "user": {"avatarUrl": "https://www.