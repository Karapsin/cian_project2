": 552, "isEmergency": false, "demolishedInMoscowProgramm": false, "houseHeatSupplyType": "central", "houseOverhaulFundType": "regionalOp", "houseGasSupplyType": "without", "houseOverlapType": "concrete", "lifts": 19, "seriesName": "Индивидуальный проект"}}, "stats": {"daily": 4, "total": 1118, "totalViewsFormattedString": "1118 просмотров, 4 за сегодня", "totalUniqueViewsFormattedString": "633 уникальных"}, "notes": {}, "agent": {"id": 451806, "cianUserId": 451806, "realtyUserId": 5667597, "accountType": "agency", "companyName": "ZIP Realty", "creationDate": "2014-02-10T19:09:48.497000+00:00", "name": "ZIP Realty", "isPro": true, "description": "ZIP Realty является членом Гильдии Риэлторов Москвы, сертифицирована по стандартам Российской Гильдии Риэлторов, сотрудники аттестованы согласно действующим профессиональным стандартам, также состоит в Гильдии Риэлторов при Московской Торгово-Промышленной Палате, в ассоциации агентств рынка элитной недвижимости AREA, ассоциации консультантов рынка коммерческой недвижимости КОКОН.\n\nОсновной специализацией компании на протяжении длительного периода была работа в сегментах готового городского жилья и новостроек бизнес-класса. Впоследствии ценовой диапазон объектов в работе нашего агентства был расширен от стандартного класса до элитного уровня.\n\nМы занимаем лидирующие позиции в реализации апартаментов-студий, ежемесячно продавая до 50 таких объектов.\n\nНаша команда обладает необходимыми навыками и компетенциями для работы с объектами коммерческой недвижимости, преимущественно формата стрит-ритейл, совершая сделки купли-продажи и аренды с объектами от 10 до нескольких тысяч квадратных метров. Среди наших постоянных клиентов как федеральные сетевые магазины, так и региональные монопродуктовые сети и субъекты малого предпринимательства.", "phones": [{"confirmed": true}, {"confirmed": false}], "skills": [{"id": 711, "name": "жилая", "parentName": "Продажа недвижимости"}, {"id": 712, "name": "жилая", "parentName": "Аренда недв