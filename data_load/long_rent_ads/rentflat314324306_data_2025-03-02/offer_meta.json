.cdn-cian.ru/images/2415378500-1.jpg", "https://images.cdn-cian.ru/images/2415378511-1.jpg", "https://images.cdn-cian.ru/images/2415378618-1.jpg", "https://images.cdn-cian.ru/images/2415378751-1.jpg", "https://images.cdn-cian.ru/images/2415378890-1.jpg", "https://images.cdn-cian.ru/images/2415379045-1.jpg", "https://images.cdn-cian.ru/images/2415379184-1.jpg", "https://images.cdn-cian.ru/images/2415379329-1.jpg", "https://images.cdn-cian.ru/images/2415699304-1.jpg", "https://images.cdn-cian.ru/images/2415706382-1.jpg", "https://images.cdn-cian.ru/images/2415379627-1.jpg", "https://images.cdn-cian.ru/images/2415379753-1.jpg"], "description": "id 549618Сдам в аренду просторную 4комнатную квартиру, расположенную в историческом сталинском доме, выбравшем в качестве своих жильцов таких именитых людей, как академики, архитекторы, художники и политические деятели. В квартире имеется современная кухня, оборудованная встроенной техникой, включая посудомоечную машину и фильтр для питьевой воды. Удобство также добавляют стиральная машина и кондиционеры в каждой комнате. Здесь предусмотрены два санузла, один из которых оснащен ванной.Квартира впечатляет высокими потолками  3,2 метра  и предлагает роскошные виды на тихий, зелёный внутренний двор из окон. Уютный и ухоженный подъезд создает атмосферу респектабельности, в которой приятно находиться. В доме живут культурные и уважаемые соседи.Безопасность арендаторов обеспечивается охранной сигнализацией внутри квартиры, а также круглосуточным видеонаблюдением придомовой территории  и охранной внутри подъезда. Для удобства жителей предусмотрены два лифта. Парковка для автомобилей осуществляется во дворе с контролем доступа через шлагбаум, что гарантирует безопасность вашего транспортного средства. Обратите внимание на развитую инфраструктуру района в пешей доступности находятся театры, рестораны, Арбат, Зоопарк, набережная Москвыреки и МоскваСити, до которых можно доехать на машине всего за 5 минут. Также буквально в 100 метрах от дома образцовая элитная школа и детский сад, что станет ценным достоянием для семьи с ребенком. Этот район предлагает всё для комфортной и насыщенной городской жизни. Не упустите возможность арендовать уникальную квартиру в сердце столицыНомер объекта 15496188771", "sku": 314324306, "brand": {"@type": "Brand", "name": "Циан"}, "review": {"@type": "Review", "reviewRating": {"@type": "Rating", "ratingValue": 5, "bestRating": 5}, "author": {"@type": "Person", "name": "Юрий Пивень"}}, "offers": {"@type": "Offer", "url": "https://www.cian.ru/rent/flat/314324306/", "priceCurrency": "RUB", "availability": "https://schema.org/InStock", "price": 250000}}}, "trackingUrl": "/rent/flat/JK/obl_id=1/city_id=1/object_type=/ga_obj_type=4/rent_type=long/spec=agent/314324306/from_developer=0/repres=0/owner=0/pod_snos=0/nv=0/", "amenities": [{"title": "В квартире есть", "id": "flatRent", "amenities": [{"value": "Посудомоечная машина", "theme": "dishwasher"}, {"value": "Стиральная машина", "theme": "washing"}, {"value": "Кондиционер", "theme": "cond"}, {"value": "Интернет", "theme": "internet"}, {"value": "Ванна", "theme": "bath"}, {"value": "Мебель на кухне", "theme": "kitchen"}]}], "newbuildingRating": 0, "offerPrice": "250 000 ₽/мес.", "company": null}, "promotionsVillageData": {}, "offerStatsPopup": {"dataStats": null, "isOpen": false, "messageError": "", "statusFetch": 0}, "pageData": {"dealType": "rent", "offerId": 314324306, "offerType": "flat", "subdomain": "www"}, "phoneCollapse": false, "phoneWarning": {"isOpen": false, "target": null}, "printModal": {"isCommentsVisible": true, "isOpen": false, "isPhonesVisible": true, "isPrintModeEnabled": false}, "pushSubscribed": false, "reclaimModal": {"errorMessage": "", "isOpen": false, "statusFetch": "none"}, "remove": {"activeFrame": "initial", "isOpen": false, "status": "default"}, "seoLinks": {"isLoad": false, "seoLinks": {"seoBlocks": []}}, "serviceBaseUrl": "https://service.cian.ru/", "similarOffers": {"userBased": {"list": [], "wi