or": false, "status": "published", "isSubAgent": false, "isMessagingEnabled": false, "isPassportVerified": true, "isSelfEmployed": false, "isPrivateBroker": false, "isCianPartner": false, "canShowOnline": true, "moderationInfo": {"qualityLevelInfo": {"levelSystemName": "max", "levelName": "Суперагент", "levelOrder": 4, "hasVerifiedDocuments": true, "highResponsibility": true, "isSuperAgent": true, "isSuperHost": false, "isBlocked": false, "showSuperHost": false, "showSuperAgent": true, "showHighResponsibility": true}, "isUserIdentified": true, "isUserIdentifiedByDocuments": true, "showUserIdentifiedByDocuments": false}, "isHidden": false, "agentLists": []}, "user": {"isAuthenticated": false, "permissions": {"canModerateUsers": false, "canModerateAnnouncements": false, "canModerateAnnouncementsExpert": false, "canViewUsers": false, "canViewAnnouncements": false}, "ga": {"type": "", "balance": 0, "packages": [], "emailMd5": ""}}, "agentAvailability": {"userId": 69400673, "available": false, "message": "Напишите ему или позвоните завтра.", "title": "Специалист работает с 10:00 по 22:00.", "availableFrom": "2025-03-24T10:00:00+03:00", "availableTo": "2025-03-24T22:00:00+03:00"}, "agentReviews": {"approvedReviewsCount": 17, "entityName": "", "entityRate": 0.8705882352941176, "entityRateMax": 5, "entityRateMin": 1, "isNotificationDisabled": true, "isUserMobilePushSubscribed": false, "isUserSubscribed": false, "rateCounts": [{"count": 14, "rate": 5}, {"count": 0, "rate": 4}, {"count": 0, "rate": 3}, {"count": 1, "rate": 2}, {"count": 2, "rate": 1}], "reviews": [{"answers": [], "created": 1645955561, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1646227981}, "rate": 5, "reviewId": "012551ae-97b3-11ec-8dbb-52ef395be8c3", "status": "approved", "text": "Максим очень хорошый и опытный специалист,он знает свое дело,он очень помог на сквартирой,мы ему очень благодарны,я Максиму желаю удачи🙏", "totalAnswers": 0, "updated": 1645955608, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=75633406&t=1&p=2", "id": 75633406, "name": "ID:75633406", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [{"answerId": "e662ba1e-5eb8-11ed-8765-8638680eef9e", "created": 1667838375, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1669887500}, "status": "approved", "text": "Иногда физически не успеваешь ответить на пару звонков, которые идут в интервале живу минут, а когда их 10 за полчаса, из-за дешевой цены квартиры, собственник попросил повысить, вроде бы тут ничего сверхъестественного. Или если вам не успевают ответить, вы сразу любите писать плохой отзыв?))", "updated": 1667838375, "user": {"avatarUrl": "https://www.cian.ru/api/get-avatar/?i=38534330&t=2&p=2&timestamp=1668584554", "id": 69400673, "name": "Москалев Максим", "socialNetworks": []}, "userLikeStatus": "unknown"}], "created": 1667041837, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1667224441}, "rate": 1, "reviewId": "512be7e4-577a-11ed-939e-861258313afc", "status": "approved", "text": "Не отвечает на звонки по объявлению, после каждого моего звонка поднимает цену аренды в объявлении.", "totalAnswers": 1, "updated": 1667041837, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=90065116&t=1&p=2", "id": 90065116, "name": "ID:90065116", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1667839365, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1668174067}, "rate": 5, "reviewId": "349499a8-5ebb-11ed-add5-921c33e9ae23", "status": "approved", "text": "В кратчайшие сроки выполнил свою работу идеально. Могу с полной уверенностью порекомендовать данные услуги.", "totalAnswers": 0, "updated": 1667839365, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=78964742&t=1&p=2", "id": 78964742, "name": "ID:78964742", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1668826626, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1669288646}, "rate": 5, "reviewId": "d9f764e0-67b5-11ed-a4cf-16b1f85bda21", "status": "approved", "text": "С Максимом работаю второй раз.Подбор арендаторов и проведение по сделке на высшем уровне.Всё чётко и грамотно.Рекомендую.", "totalAnswers": 0, "updated": 1668826626, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=97323758&t=1&p=2", "id": 97323758, "name": "ID:97323758", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1669123761, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1669125685}, "rate": 5, "reviewId": "ac65b2f0-6a69-11ed-baf2-3a16f35e0189", "status": "approved", "text": "Помог сдать квартиру, с которой я провозился 3 месяца за 2 дня! Причём не просто нашел одного жильца а предложил большой выбор клиентов, чтобы я мог выбрать. Очень приятно общаться, человек действительно погружен и заинтересован в работе, как для себя) Оперативная работа, так еще и бесплатно!", "totalAnswers": 0, "updated": 1669123761, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=78202679&t=1&p=2", "id": 78202679, "name": "ID:78202679", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1670318121, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1670855658}, "rate": 5, "reviewId": "82b4d278-7546-11ed-99c6-16ac78debe4d", "status": "approved", "text": "Максим ставлю Вам 5 авансом чтоб вы наконец взяли трубку и показали квартиру на Кутузовской в Трехгорке 😈😈😈 Писала сообщения и звонила с вскр, тел на -3038 заканчивается, дайте обратную связь!)", "totalAnswers": 0, "updated": 1670318121, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=19385750&t=1&p=2", "id": 19385750, "name": "Кудренко Юлия", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1682098297, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1682349452}, "rate": 5, "reviewId": "5e588476-e06a-11ed-b9b1-5618432f93cf", "status": "approved", "text": "всё хорошо договорились о съёме жилья всё отлично", "totalAnswers": 0, "updated": 1682098297, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=101960411&t=1&p=2", "id": 101960411, "name": "ID:101960411", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1696700107, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1696942588}, "rate": 5, "reviewId": "db7b5bac-6537-11ee-bc15-2ab3b02ec956", "status": "approved", "text": "Услугами Максима пользуюсь не один год. Подбирает замечательных людей, оперативно. Грамотный договор, полное взаимопонимание.", "totalAnswers": 0, "updated": 1696700107, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=54483858&t=1&p=2", "id": 54483858, "name": "ID:54483858", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [{"answerId": "a3f6391a-683c-11ee-9482-e23e98b7dc55", "created": 1697032015, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1697032019}, "status": "approved", "text": "Спасибо за теплые и честные слова! Стараюсь всегда делать свою работу добросовестно и качественно!", "updated": 1697032015, "user": {"avatarUrl": "https://www.cian.ru/api/get-avatar/?i=38534330&t=2&p=2&timestamp=1668584554", "id": 69400673, "name": "Москалев Максим", "socialNetworks": []}, "userLikeStatus": "unknown"}], "created": 1696873740, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1697025677}, "rate": 5, "reviewId": "2099abea-66cc-11ee-b6d1-0acb63252fcf", "status": "approved", "text": "Огромное спасибо Максиму! После неделей самостоятельного безрезультатного поиска, я обратился к Максиму и в максимально кратчайшие сроки, он нашел идеальный вариант съёмного житья на потрясающих условиях! Искренне всем рекомендую!!!", "totalAnswers": 1, "updated": 1696873740, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=108495812&t=1&p=2", "id": 108495812, "name": "ID:108495812", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1696957292, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 16