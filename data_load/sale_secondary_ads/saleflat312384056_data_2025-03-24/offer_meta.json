xd?i=89048505&t=1&p=2", "id": 89048505, "name": "ID:89048505", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1665661310, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1665683893}, "rate": 5, "reviewId": "068ba14c-4aec-11ed-ab33-1e4e06e69206", "status": "approved", "text": "Сделка состоялась. Грамотный и вежливый специалист. Спасибо!", "totalAnswers": 0, "updated": 1665661310, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=78733310&t=1&p=2", "id": 78733310, "name": "ID:78733310", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1676666904, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1676888544}, "rate": 5, "reviewId": "6c0af938-af04-11ed-ad40-7ac2265a7b71", "status": "approved", "text": "Порядочный специалист, любящий своё дело.\nСделка состоялась, все договорённости соблюдены. Рекомендую!", "totalAnswers": 0, "updated": 1676666904, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=80585458&t=1&p=2", "id": 80585458, "name": "ID:80585458", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1678805258, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1679404484}, "rate": 5, "reviewId": "2a2f2260-c277-11ed-9c66-3ea2d5e8d290", "status": "approved", "text": "Спасибо за партнерскую сделку! Всё чётко, грамотно, в максимально короткие сроки. Очень приятно работать и общаться. Рекомендуем клиентам и партнерам!", "totalAnswers": 0, "updated": 1678805258, "user": {"avatarUrl": "https://www.cian.ru/api/get-avatar/?i=127195&t=2&p=2&timestamp=1666255488", "id": 2231164, "name": "Городское агентство недвижимости", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1678807819, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1679403786}, "rate": 5, "reviewId": "2104dfee-c27d-11ed-bc55-6a2ecbf2b07c", "status": "approved", "text": "грамотная, милая девушка. все прошло быстро и хорошо.", "totalAnswers": 0, "updated": 1678807819, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=78155349&t=1&p=2", "id": 78155349, "name": "ID:78155349", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1679741960, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1680592285}, "rate": 5, "reviewId": "185df0c4-cafc-11ed-8621-92f7d95ecca9", "status": "approved", "text": "Вежливый и отзывчивый специалист, все прошло хорошо. Спасибо!", "totalAnswers": 0, "updated": 1679741960, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=100746621&t=1&p=2", "id": 100746621, "name": "ID:100746621", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1681739557, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1681897905}, "rate": 5, "reviewId": "1cd781be-dd27-11ed-8cf5-2e3eb3153a0d", "status": "approved", "text": "Диана очень приятная женщина, не пожалел, что обратился, за 5 минут по телефону договорились, увиделись, квартира и условия соответствуют заявленному, все Гуд, рекомендую", "totalAnswers": 0, "updated": 1681739557, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=60387609&t=1&p=2", "id": 60387609, "name": "Притчин Алексей ", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1685077186, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1685347054}, "rate": 5, "reviewId": "22712b2e-fb82-11ed-a62b-62d4de4907d8", "status": "approved", "text": "очень и очень приятная женшина и не только хороший риелтор но и очень симпатичная женшина. \nогромное вам спасибо Диана. \nсоветую всем обратиться за помощью к Диане,не обманет и все объяснит, всё официально и качественно. \nспасибо ещё раз 🙏🙏🙏🙏🙏💕", "totalAnswers": 0, "updated": 1685077186, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=91515340&t=1&p=2", "id": 91515340, "name": "ID:91515340", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1689328615, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1689835084}, "rate": 5, "reviewId": "c41af966-222c-11ee-9441-f67545860893", "status": "approved", "text": "Настоящий профессионал! Благодарим за оперативность и сотрудничество! Чувствовалась забота, ответственность к своей работе!\nСделка состоялась, ДИАНЕ ЖИЛИНЕ пять звёзд! РЕКОМЕНДУЮ!\nP.S.: читайте внимательно объявления, этим вы проявите уважение к человеку, к его кропотливой работе, где время самое ценное что есть! \nУдачи всем, спасибо большое обеим сторонам!", "totalAnswers": 0, "updated": 1689328615, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=96984092&t=1&p=2", "id": 96984092, "name": "ID:96984092", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1690491191, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1690884587}, "rate": 5, "reviewId": "9929f110-2cbf-11ee-abd9-8e788e82316b", "status": "approved", "text": "Диана профессионал своего дела! Очень вежливая в общении, все подскажет, во всех вопросах поможет, сделка состоялась, благодаря ей нашла ту самую квартиру😍 Просто добрейший души человек🤍 Очень ответственно относится к своей работе!", "totalAnswers": 0, "updated": 1690491191, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=78734931&t=1&p=2", "id": 78734931, "name": "ID:78734931", "socialNetworks": []}, "userLikeStatus": "unknown"}], "subscriptionEmail": "", "totalCount": 24}, "isHiddenByUser": false, "degradationInfo": {}, "newbuildingsNearby": {"title": "Новостройки поблизости", "text": "Новые жилые комплексы с выгодными ставками по ипотеке", "newbuildings": [{"imageUrl": "https://images.cdn-cian.ru/images/1y-izmaylovskiy-moskva-jk-2237140695-7.jpg", "url": "https://zhk-1-y-izmaylovskiy-i.cian.ru/", "name": "ЖК «1-й Измайловский»", "minPrice": "от 10 828 350 ₽", "underground": {"name": "Щёлковская", "lineColor": "03238B"}, "analytics": {"id": 4588710, "position": 1, "type": "JK"}}, {"imageUrl": "https://images.cdn-cian.ru/images/2y-irtyshskiy-moskva-jk