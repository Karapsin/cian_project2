me": "Чумичева", "parentId": 3914321, "parentCianId": 96955, "isRecidivist": false, "isUserOffersHasErrors": false, "offersCount": 1379, "offersLink": "https://www.cian.ru/company/96955/", "availableServices": {"isUploadsAvailable": true, "isCallTrackingAvailable": false, "isPhoneChangingAvailable": false, "isServicePackagesAvailable": false, "canUseHiddenBase": true}, "userType": "realtor_based", "removeCompetitor": false, "status": "hidden", "isSubAgent": true, "isMessagingEnabled": false, "isPassportVerified": false, "isSelfEmployed": false, "isPrivateBroker": false, "masterAgent": {"cianUserId": 96955, "realtyUserId": 3914321, "absoluteAvatarUrl": "https://www.cian.ru/api/get-avatar/?i=48682&t=2&p=2&timestamp=1741357531", "absoluteMiniAvatarUrl": "https://www.cian.ru/api/get-avatar/?i=48682&t=2&p=1&timestamp=1741357531", "experience": "2012", "accountType": "agency", "creationDate": "2011-01-25T22:51:39+00:00", "offersCount": 1379}, "isCianPartner": false, "canShowOnline": false, "moderationInfo": {"qualityLevelInfo": {"levelSystemName": "high", "levelName": "Надёжный агент", "levelOrder": 3, "hasVerifiedDocuments": false, "highResponsibility": true, "isSuperAgent": false, "isSuperHost": false, "isBlocked": false, "showSuperHost": false, "showSuperAgent": false, "showHighResponsibility": true}, "isUserIdentified": false, "isUserIdentifiedByDocuments": true, "showUserIdentifiedByDocuments": true}, "isHidden": true, "metrics": [{"title": "На Циан", "value": "14 лет"}, {"title": "Объектов в работе", "value": "более 1000"}], "agentLists": []}, "specialProject": {"id": "pik", "link": "https://www.cian.ru/map/?builder=9&deal_type=2&with_newobject=1&object_type=2&currency=2&center=55.77228091175091,37.581318235024824&zoom=11&engine_version=2&newbuildings_search=true&is_pik_promo=1&region=1"}, "user": {"isAuthenticated": false, "permissions": {"canModerateUsers": false, "canModerateAnnouncements": false, "canModerateAnnouncementsExpert": false, "canViewUsers": false, "canViewAnnouncements": false}, "ga": {"type": "", "balance": 0, "packages": [], "emailMd5": ""}}, "agentAvailability": {"userId": 3914321, "available": true}, "agentReviews": {"approvedReviewsCount": 7, "entityName": "", "entityRate": 0.8, "entityRateMax": 5, "entityRateMin": 1, "isNotificationDisabled": true, "isUserMobilePushSubscribed": false, "isUserSubscribed": false, "rateCounts": [{"count": 5, "rate": 5}, {"count": 0, "rate": 4}, {"count": 0, "rate": 3}, {"count": 1, "rate": 2}, {"count": 1, "rate": 1}], "reviews": [{"answers": [], "created": 1737448820, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1737605545}, "rate": 2, "reviewId": "593b5a10-d7d3-11ef-8a18-2a3eff02c0fe", "status": "approved", "text": "Девушка безусловно приятная, говорит красиво и грамотно, но есть нюансы. Предложили сдать мои квартиры-отдал ключи - а потом сообщают мне на следующий день что с меня комиссия 50% - мягко говоря был удивлен таким не профессиональным подходом(сказала - что видимо забыла сообщить). Остается только надеяться что это случайность - а не тенденция. Ключи забрал. Успехов в работе.", "totalAnswers": 0, "updated": 1737448820, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=15985537&t=1&p=2", "id": 15985537, "name": "ID:15985537", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1737716488, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1737736949}, "rate": 5, "reviewId": "8ff50f94-da42-11ef-af21-0eba9e12481d", "status": "approved", "text": "Хочу оставить положительный опыт работы с Кариной. \nКарина за короткое время сдала мою квартиру в ЖК Зиларт. Всегда была на связи. Очень компетентный и грамотный риелтор!", "totalAnswers": 0, "updated": 1737716488, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=7208878&t=1&p=2", "id": 7208878, "name": "ID:7338365", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1738048158, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1738148913}, "rate": 5, "reviewId": "ca79bd48-dd46-11ef-b9cc-9ec699f8dd52", "status": "approved", "text": "Карина грамотный , профессиональный риелтор. Всё быстро, четко и понятно( быстрый подбор клиентов на показ)", "totalAnswers": 0, "updated": 1738048158, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=127102658&t=1&p=2", "id": 127102658, "name": "ID:127102658", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1738303465, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1738333350}, "rate": 5, "reviewId": "3986d1fe-df99-11ef-aabc-9abf9cb69f23", "status": "approved", "text": "Понравилось сотрудничать с Кариной и юристом Максимом, все было оперативно, выход на сделку, все проверили, согласовывали много раз, комфортно и приятно работать! Будем еще обращаться, успехов вам!", "totalAnswers": 0, "updated": 1738303465, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=45431577&t=1&p=2", "id": 45431577, "name": "ID:45431577", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1738344105, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1738425593}, "rate": 5, "reviewId": "d88c69d6-dff7-11ef-aabc-9abf9cb69f23", "status": "approved", "text": "Карина отличный специалист. Покупатели нашлись достаточно быстро. Показы, переговоры и сама сделка были хорошо организованы.\nСпасибо за работу!", "totalAnswers": 0, "updated": 1738344105, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=13407753&t=1&p=2", "id": 13407753, "name": "Новиков Дмитрий Евгеньевич", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1738862007, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1738924598}, "rate": 1, "reviewId": "ae7abbf6-e4ad-11ef-ac9b-eea39b1a8bfb", "status": "approved", "text": "На тратьте время на этого риэлтора. Общались по нескольким квартирам ни с одной не дошли до сделки, хотя у нас были наличные. Мутит воду, сначала сказала в порядке и без занижения продают, потом оказывается с\nзанижением. Сначала покажем квартиру, потом собственник не смог. И так по каждой квартире. Потом начала врать, что есть покупатель, поднимать цену когда мы просто хотели посмотреть и купить в конце концов. В общем так себе, с ветерком :) Безответственная дама.", "totalAnswers": 0, "updated": 1738862007, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=73922769&t=1&p=2", "id": 73922769, "name": "Вершинина Кристина", "socialNetworks": []}, "userLikeStatus": "unknown"}, {"answers": [], "created": 1741887610, "dislikesCount": 0, "likesCount": 0, "moderation": {"date": 1741956594}, "rate": 5, "reviewId": "361a61a2-0032-11f0-9369-1e4f768eece8", "status": "approved", "text": "Арендовала недавно квартиру в ЖК «Зиларт» с помощью Карины! Всё быстро, оперативно, без проблем. Карина всегда была на связи и отвечала на любые вопросы. Очень благодарна за работу!", "totalAnswers": 0, "updated": 1741887709, "user": {"avatarUrl": "https://www.cian.ru/avatar.axd?i=128726939&t=1&p=2", "id": 128726939, "name": "ID:128726939", "socialNetworks": []}, "userLikeStatus": "unknown"}], "subscriptionEmail": "", "totalCount": 7}, "isHiddenByUser": false, "degradationInfo": {}, "priceInfo": {"pricePerSquareValue": 638095}, "rosreestrInfoV2": {"showCheckedLabel": false}, "isOnlineRegistrationAvailable": false, "factoids": [{"title": "Общая площадь", "icon": "https://images.cdn-cian.ru/imgmobile/icons/offer_card/size.svg", "value": "42 м²"}, {"title": "Жилая площадь", "icon": "https://images.cdn-cian.ru/imgmobile/icons/offer_card/plan.svg", "value": "12 м²"}, {"title": "Площадь кухни", "icon": "https://images.cdn-cian.ru/imgmobile/icons/offer_card/kitchen.svg", "value": "20 м²"}, {"title": "Этаж", "icon": "https://images.cdn-cian.ru/imgmobile/icons/offer_card/floor.svg", "value": "12 из 14"}, {"title": "Год постройки", "icon": "https://images.cdn-cian.ru/imgmobile/icons/offer_card/build_year.svg", "value": "2023"}], "sidebar": [{"title": "Цена за м