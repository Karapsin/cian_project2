.jpg"], "description": "Один взрослый собственник, полная стоимость в договоре. Одно из лучших мест в районе, в непосредственной близости продуктовые магазины, школы, детские сады, обновленные поликлиники, два фитнес зала, рестораны и все что нужно для комфортной жизни. 10 минут пешком до метро Алтуфьево или Бибирево. Проблем с парковкой автомобиля не бывает. Хорошие соседи. Огромная лоджия где можно сделать зону отдыха или кабинет, уютная и светлая комната. Достойный вид из окна , нету эффекта окна в окна. Дом очень удачно расположен, утром солнце не нагревает квартиру и не мешает спать, а вечером радует красивым закатом. Свежие пластиковые окна. Без обременений.Большая просьба риелторов без покупателей не беспокоить", "sku": 315098791, "brand": {"@type": "Brand", "name": "Циан"}, "review": {"@type": "Review", "reviewRating": {"@type": "Rating", "ratingValue": 5, "bestRating": 5}, "author": {"@type": "Person", "name": ""}}, "offers": {"@type": "Offer", "url": "https://www.cian.ru/sale/flat/315098791/", "priceCurrency": "RUB", "availability": "https://schema.org/InStock", "price": 10500000}}}, "trackingUrl": "/sale/flat/JK/obl_id=1/city_id=1/object_type=1/ga_obj_type=1/spec=none/315098791/from_developer=0/repres=0/owner=1/pod_snos=0/nv=0/", "amenities": [], "newbuildingRating": 0, "offerPrice": "10 500 000 ₽", "newbuildingFlatSaleQueryString": "/cat.php?deal_type=sale&engine_version=2&object_type%5B0%5D=2&offer_type=flat&region=1&from_developer=1&maxprice=15500000&decorations_list%5B0%5D=fine&decorations_list%5B1%5D=fineWithFurniture&decorations_list%5B2%5D=preFine", "company": null}, "promotionsVillageData": {}, "offerStatsPopup": {"dataStats": null, "isOpen": false, "messageError": "", "statusFetch": 0}, "pageData": {"dealType": "sale", "offerId": 315098791, "offerType": "flat", "subdomain": "www"}, "phoneCollapse": false, "phoneWarning": {"isOpen": false, "target": null}, "printModal": {"isCommentsVisible": true, "isOpen": false, "isPhonesVisible": true, "isPrint