м. И.М.Сеченова, кафедра экономики и менеджмента ИСН.В апартаментах, рассчитанных на 6 человек, есть 2 двуспальных кровати, раскладной диван, шкаф, WiFi, телевизор, гладильная доска, утюг, сушилка, постельное бельё, комплект полотенец. На кухне плита, духовка, микроволновая печь, чайник, холодильник. В ванной комнате стиральная машина, фен. Для гостей на машине предусмотрена платная парковка.", "sku": 293793246, "brand": {"@type": "Brand", "name": "Циан"}, "review": {"@type": "Review", "reviewRating": {"@type": "Rating", "ratingValue": 4.5, "bestRating": 5}, "author": {"@type": "Person", "name": "Партнёр Циан"}}, "offers": {"@type": "Offer", "url": "https://www.cian.ru/rent/flat/293793246/", "priceCurrency": "RUB", "availability": "https://schema.org/InStock", "price": 5151}}}, "trackingUrl": "/rent/flat/JK/obl_id=1/city_id=1/object_type=/ga_obj_type=1/rent_type=daily/spec=company/293793246/from_developer=0/repres=0/owner=0/pod_snos=0/nv=0/", "amenities": [{"title": "В квартире есть", "id": "flatRent", "amenities": [{"value": "Мебель в комнатах", "theme": "furniture"}]}], "newbuildingRating": 0, "offerPrice": "от 5 151 ₽/сут.", "company": null}, "promotionsVillageData": {}, "offerStatsPopup": {"dataStats": null, "isOpen": false, "messageError": "", "statusFetch": 0}, "pageData": {"dealType": "rent", "offerId": 293793246, "offerType": "flat", "subdomain": "www"}, "phoneCollapse": false, "phoneWarning": {"isOpen": false, "target": null}, "printModal": {"isCommentsVisible": true, "isOpen": false, "isPhonesVisible": true, "isPrintModeEnabled": false}, "pushSubscribed": false, "reclaimModal": {"errorMessage": "", "isOpen": false, "statusFetch": "none"}, "remove": {"activeFrame": "initial", "isOpen": false, "status": "default"}, "seoLinks": {"isLoad": false, "seoLinks": {"seoBlocks": []}}, "serviceBaseUrl": "https://service.cian.ru/", "similarOffers": {"userBased": {"list": [], "withoutCompetitors": false, "modelVersion": ""}, "itemBased": {"list": [], "withoutCompetitors